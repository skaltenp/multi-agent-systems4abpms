            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "WITH haus_counts AS (\n  SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n  FROM J09C_temp\n  GROUP BY HAUS\n)\nUPDATE J09C_temp\nSET ENTSCHEIDUNG = CASE\n  WHEN HOUSE_NUM1 = 0 THEN 'EVU'\n  WHEN HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n  WHEN hc.eq_count < 3 THEN 'KSA'\n  ELSE 'EVU'\nEND\nFROM haus_counts hc\nWHERE J09C_temp.HAUS = hc.HAUS;"
