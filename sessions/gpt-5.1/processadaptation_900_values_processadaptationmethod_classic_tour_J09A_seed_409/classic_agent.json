            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH base AS (\n    SELECT t.*, eablg.\"Meter Reading (MR) Doc. No.\" AS MR_Doc_No\n    FROM J09A_temp t\n    LEFT JOIN eablg ON eablg.Installation = t.ANLAGE\n),\nnet AS (\n    SELECT\n        b.MR_Doc_No,\n        b.HAUS,\n        b.ANLAGE,\n        b.ME_MA_ID,\n        b.EQUNR,\n        b.HOUSE_NUM1,\n        b.ENTSCHEIDUNG,\n        n.TITLE,\n        n.FORENAME,\n        n.SURNAME,\n        n.STREET,\n        n.STREETNO,\n        n.POST_CODE1,\n        n.CITY1,\n        n.CITY2,\n        n.EMAIL\n    FROM base b\n    LEFT JOIN net_master n ON n.EQUNR = b.EQUNR\n),\nsales AS (\n    SELECT\n        b.MR_Doc_No,\n        b.HAUS,\n        b.ANLAGE,\n        b.ME_MA_ID,\n        b.EQUNR,\n        b.HOUSE_NUM1,\n        b.ENTSCHEIDUNG,\n        s.TITLE,\n        s.FORENAME,\n        s.SURNAME,\n        s.STREET,\n        s.STREETNO,\n        s.POST_CODE1,\n        s.CITY1,\n        s.CITY2,\n        s.EMAIL\n    FROM base b\n    LEFT JOIN sales_master s ON s.EQUNR = b.EQUNR\n),\ncombined AS (\n    SELECT\n        COALESCE(sales.MR_Doc_No, net.MR_Doc_No) AS \"Meter Reading (MR) Doc. No.\",\n        COALESCE(sales.HAUS, net.HAUS) AS HAUS,\n        COALESCE(sales.ANLAGE, net.ANLAGE) AS ANLAGE,\n        COALESCE(sales.ME_MA_ID, net.ME_MA_ID) AS ME_MA_ID,\n        COALESCE(sales.EQUNR, net.EQUNR) AS EQUNR,\n        COALESCE(sales.HOUSE_NUM1, net.HOUSE_NUM1) AS HOUSE_NUM1,\n        COALESCE(sales.ENTSCHEIDUNG, net.ENTSCHEIDUNG) AS ENTSCHEIDUNG,\n        CASE WHEN sales.TITLE IS NOT NULL THEN sales.TITLE ELSE net.TITLE END AS TITLE,\n        CASE WHEN sales.TITLE IS NOT NULL THEN sales.FORENAME ELSE net.FORENAME END AS FORENAME,\n        CASE WHEN sales.TITLE IS NOT NULL THEN sales.SURNAME ELSE net.SURNAME END AS SURNAME,\n        CASE WHEN sales.TITLE IS NOT NULL THEN sales.STREET ELSE net.STREET END AS STREET,\n        CASE WHEN sales.TITLE IS NOT NULL THEN sales.STREETNO ELSE net.STREETNO END AS STREETNO,\n        CASE WHEN sales.TITLE IS NOT NULL THEN sales.POST_CODE1 ELSE net.POST_CODE1 END AS POST_CODE1,\n        CASE WHEN sales.TITLE IS NOT NULL THEN sales.CITY1 ELSE net.CITY1 END AS CITY1,\n        CASE WHEN sales.TITLE IS NOT NULL THEN sales.CITY2 ELSE net.CITY2 END AS CITY2,\n        CASE WHEN sales.TITLE IS NOT NULL THEN sales.EMAIL ELSE net.EMAIL END AS EMAIL\n    FROM net\n    LEFT JOIN sales ON net.EQUNR = sales.EQUNR\n)\nSELECT\n    \"Meter Reading (MR) Doc. No.\",\n    HAUS,\n    ANLAGE,\n    ME_MA_ID,\n    EQUNR,\n    HOUSE_NUM1,\n    ENTSCHEIDUNG,\n    TITLE,\n    FORENAME,\n    SURNAME,\n    STREET,\n    STREETNO,\n    POST_CODE1,\n    CITY1,\n    CITY2,\n    EMAIL\nFROM combined;",
              "filename": "J09A"
