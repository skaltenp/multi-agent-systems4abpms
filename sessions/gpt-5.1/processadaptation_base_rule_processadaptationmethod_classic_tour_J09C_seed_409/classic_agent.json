          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TABLE J09C_temp AS\nSELECT d.*,\n       CASE \n         WHEN cnt.cnt_eq < 3 THEN 'KSA'\n         ELSE 'EVU'\n       END AS ENTSCHEIDUNG\nFROM decision_table d\nJOIN (\n  SELECT HAUS, COUNT(DISTINCT EQUNR) AS cnt_eq\n  FROM decision_table\n  WHERE TOUR LIKE 'J09C%'\n  GROUP BY HAUS\n) cnt\n  ON d.HAUS = cnt.HAUS\nWHERE d.TOUR LIKE 'J09C%';"
