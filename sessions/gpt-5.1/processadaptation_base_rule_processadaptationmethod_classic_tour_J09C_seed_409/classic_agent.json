          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH base AS (\n  SELECT \n    j.\"HAUS\",\n    j.\"ANLAGE\" AS ANLAGE,\n    j.\"ME_MA_ID\",\n    j.\"EQUNR\",\n    j.\"HOUSE_NUM1\",\n    j.\"ENTSCHEIDUNG\",\n    e.\"Meter Reading (MR) Doc. No.\" AS MR_Doc_No\n  FROM J09C_temp j\n  LEFT JOIN eablg e\n    ON e.\"Installation\" = j.\"ANLAGE\"\n),\nnet AS (\n  SELECT \n    b.MR_Doc_No,\n    b.HAUS,\n    b.ANLAGE,\n    b.ME_MA_ID,\n    b.EQUNR,\n    b.HOUSE_NUM1,\n    b.ENTSCHEIDUNG,\n    n.TITLE AS n_TITLE,\n    n.FORENAME AS n_FORENAME,\n    n.SURNAME AS n_SURNAME,\n    n.STREET AS n_STREET,\n    n.STREETNO AS n_STREETNO,\n    n.POST_CODE1 AS n_POST_CODE1,\n    n.CITY1 AS n_CITY1,\n    n.CITY2 AS n_CITY2,\n    n.EMAIL AS n_EMAIL\n  FROM base b\n  LEFT JOIN net_master n\n    ON b.EQUNR = n.EQUNR\n),\nsales AS (\n  SELECT \n    b.MR_Doc_No,\n    b.HAUS,\n    b.ANLAGE,\n    b.ME_MA_ID,\n    b.EQUNR,\n    b.HOUSE_NUM1,\n    b.ENTSCHEIDUNG,\n    s.TITLE AS s_TITLE,\n    s.FORENAME AS s_FORENAME,\n    s.SURNAME AS s_SURNAME,\n    s.STREET AS s_STREET,\n    s.STREETNO AS s_STREETNO,\n    s.POST_CODE1 AS s_POST_CODE1,\n    s.CITY1 AS s_CITY1,\n    s.CITY2 AS s_CITY2,\n    s.EMAIL AS s_EMAIL\n  FROM base b\n  LEFT JOIN sales_master s\n    ON b.EQUNR = s.EQUNR\n)\nSELECT\n  COALESCE(sales.MR_Doc_No, net.MR_Doc_No) AS \"Meter Reading (MR) Doc. No.\",\n  COALESCE(sales.HAUS, net.HAUS) AS \"HAUS\",\n  COALESCE(sales.ANLAGE, net.ANLAGE) AS \"ANLAGE\",\n  COALESCE(sales.ME_MA_ID, net.ME_MA_ID) AS \"ME_MA_ID\",\n  COALESCE(sales.EQUNR, net.EQUNR) AS \"EQUNR\",\n  COALESCE(sales.HOUSE_NUM1, net.HOUSE_NUM1) AS \"HOUSE_NUM1\",\n  COALESCE(sales.ENTSCHEIDUNG, net.ENTSCHEIDUNG) AS \"ENTSCHEIDUNG\",\n  -- Prefer sales data when present\n  CASE WHEN sales.s_TITLE IS NOT NULL THEN sales.s_TITLE ELSE net.n_TITLE END AS \"TITLE\",\n  CASE WHEN sales.s_FORENAME IS NOT NULL THEN sales.s_FORENAME ELSE net.n_FORENAME END AS \"FORENAME\",\n  CASE WHEN sales.s_SURNAME IS NOT NULL THEN sales.s_SURNAME ELSE net.n_SURNAME END AS \"SURNAME\",\n  CASE WHEN sales.s_STREET IS NOT NULL THEN sales.s_STREET ELSE net.n_STREET END AS \"STREET\",\n  CASE WHEN sales.s_STREETNO IS NOT NULL THEN sales.s_STREETNO ELSE net.n_STREETNO END AS \"STREETNO\",\n  CASE WHEN sales.s_POST_CODE1 IS NOT NULL THEN sales.s_POST_CODE1 ELSE net.n_POST_CODE1 END AS \"POST_CODE1\",\n  CASE WHEN sales.s_CITY1 IS NOT NULL THEN sales.s_CITY1 ELSE net.n_CITY1 END AS \"CITY1\",\n  CASE WHEN sales.s_CITY2 IS NOT NULL THEN sales.s_CITY2 ELSE net.n_CITY2 END AS \"CITY2\",\n  CASE WHEN sales.s_EMAIL IS NOT NULL THEN sales.s_EMAIL ELSE net.n_EMAIL END AS \"EMAIL\"\nFROM net\nLEFT JOIN sales\n  ON net.EQUNR = sales.EQUNR\nORDER BY \"HAUS\", \"EQUNR\";\n",
              "filename": "J09C"
            },
            "id": "call_WetzQDx8uxQ36pAtcPInHGRL",
