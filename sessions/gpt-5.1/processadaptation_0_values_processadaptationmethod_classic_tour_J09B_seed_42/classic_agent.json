          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH base AS (\n    SELECT \n        j.\"HAUS\",\n        j.\"ANLAGE\" AS ANLAGE,\n        j.\"ME_MA_ID\" AS ME_MA_ID,\n        j.\"EQUNR\" AS EQUNR,\n        j.\"HOUSE_NUM1\" AS HOUSE_NUM1,\n        j.\"ENTSCHEIDUNG\" AS ENTSCHEIDUNG\n    FROM J09B_temp j\n),\n\njoined AS (\n    SELECT\n        eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\",\n        b.HAUS,\n        b.ANLAGE,\n        b.ME_MA_ID,\n        b.EQUNR,\n        b.HOUSE_NUM1,\n        b.ENTSCHEIDUNG,\n        COALESCE(sales.TITLE, net.TITLE) AS TITLE,\n        COALESCE(sales.FORENAME, net.FORENAME) AS FORENAME,\n        COALESCE(sales.SURNAME, net.SURNAME) AS SURNAME,\n        COALESCE(sales.STREET, net.STREET) AS STREET,\n        COALESCE(sales.STREETNO, net.STREETNO) AS STREETNO,\n        COALESCE(sales.POST_CODE1, net.POST_CODE1) AS POST_CODE1,\n        COALESCE(sales.CITY1, net.CITY1) AS CITY1,\n        COALESCE(sales.CITY2, net.CITY2) AS CITY2,\n        COALESCE(sales.EMAIL, net.EMAIL) AS EMAIL,\n        CASE WHEN sales.EQUNR IS NOT NULL THEN 1 ELSE 0 END AS has_sales\n    FROM base b\n    LEFT JOIN eablg ON eablg.Installation = b.ANLAGE\n    LEFT JOIN net_master net ON net.EQUNR = b.EQUNR\n    LEFT JOIN sales_master sales ON sales.EQUNR = b.EQUNR\n)\n\nSELECT\n    \"Meter Reading (MR) Doc. No.\",\n    HAUS,\n    ANLAGE,\n    ME_MA_ID,\n    EQUNR,\n    HOUSE_NUM1,\n    ENTSCHEIDUNG,\n    CASE WHEN has_sales = 1 THEN TITLE ELSE NULL END AS TITLE,\n    CASE WHEN has_sales = 1 THEN FORENAME ELSE NULL END AS FORENAME,\n    CASE WHEN has_sales = 1 THEN SURNAME ELSE NULL END AS SURNAME,\n    CASE WHEN has_sales = 1 THEN STREET ELSE NULL END AS STREET,\n    CASE WHEN has_sales = 1 THEN STREETNO ELSE NULL END AS STREETNO,\n    CASE WHEN has_sales = 1 THEN POST_CODE1 ELSE NULL END AS POST_CODE1,\n    CASE WHEN has_sales = 1 THEN CITY1 ELSE NULL END AS CITY1,\n    CASE WHEN has_sales = 1 THEN CITY2 ELSE NULL END AS CITY2,\n    CASE WHEN has_sales = 1 THEN EMAIL ELSE NULL END AS EMAIL\nFROM joined;",
              "filename": "J09B"
            },
