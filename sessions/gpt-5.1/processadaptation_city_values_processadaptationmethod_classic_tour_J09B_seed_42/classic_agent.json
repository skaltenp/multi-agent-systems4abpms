              "sqlite_command": "WITH eq_counts AS (\n    SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n    FROM J09B_temp\n    GROUP BY HAUS\n)\nUPDATE J09B_temp\nSET ENTSCHEIDUNG = CASE\n    WHEN HOUSE_NUM1 = 0 THEN 'EVU'\n    WHEN HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n    WHEN HOUSE_NUM1 BETWEEN 900 AND 999 THEN 'EVU'\n    WHEN CITY1 IN ('Wiblingwerde', 'Breckerfeld') OR CITY2 IN ('Wiblingwerde', 'Breckerfeld') THEN 'EVU'\n    WHEN ec.eq_count < 3 THEN 'KSA'\n    ELSE 'EVU'\nEND\nFROM eq_counts ec\nWHERE J09B_temp.HAUS = ec.HAUS;"
            },
