              "sqlite_command": "CREATE TABLE J09B_joined AS\nSELECT d.\"Meter Reading (MR) Doc. No.\", d.HAUS, d.ANLAGE, d.ME_MA_ID, d.EQUNR, d.HOUSE_NUM1, d.ENTSCHEIDUNG,\n       n.TITLE as n_TITLE, n.FORENAME as n_FORENAME, n.SURNAME as n_SURNAME, n.STREET as n_STREET, n.STREETNO as n_STREETNO, n.POST_CODE1 as n_POST_CODE1, n.CITY1 as n_CITY1, n.CITY2 as n_CITY2, n.EMAIL as n_EMAIL,\n       s.TITLE as s_TITLE, s.FORENAME as s_FORENAME, s.SURNAME as s_SURNAME, s.STREET as s_STREET, s.STREETNO as s_STREETNO, s.POST_CODE1 as s_POST_CODE1, s.CITY1 as s_CITY1, s.CITY2 as s_CITY2, s.EMAIL as s_EMAIL\nFROM (\n  SELECT t.*, e.\"Meter Reading (MR) Doc. No.\"\n  FROM J09B_temp t\n  LEFT JOIN eabl e ON t.EQUNR = e.EQUNR\n  LEFT JOIN eablg g ON e.\"Meter Reading (MR) Doc. No.\" = g.\"Meter Reading (MR) Doc. No.\"\n) d\nLEFT JOIN net_master n ON d.EQUNR = n.EQUNR\nLEFT JOIN sales_master s ON d.EQUNR = s.EQUNR;"
