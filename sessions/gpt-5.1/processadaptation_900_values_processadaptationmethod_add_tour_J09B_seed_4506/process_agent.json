        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TABLE IF NOT EXISTS J09B_enriched AS\nWITH sales AS (\n  SELECT \n    j.*, \n    s.TITLE AS sales_TITLE,\n    s.FORENAME AS sales_FORENAME,\n    s.SURNAME AS sales_SURNAME,\n    s.STREET AS sales_STREET,\n    s.STREETNO AS sales_STREETNO,\n    s.CITY1 AS sales_CITY1,\n    s.CITY2 AS sales_CITY2,\n    s.POST_CODE1 AS sales_POST_CODE1,\n    s.EMAIL AS sales_EMAIL\n  FROM J09B_joined j\n  LEFT JOIN sales_master s ON j.EQUNR = s.EQUNR\n),\nnet AS (\n  SELECT \n    j.*, \n    n.TITLE AS net_TITLE,\n    n.FORENAME AS net_FORENAME,\n    n.SURNAME AS net_SURNAME,\n    n.STREET AS net_STREET,\n    n.STREETNO AS net_STREETNO,\n    n.CITY1 AS net_CITY1,\n    n.CITY2 AS net_CITY2,\n    n.POST_CODE1 AS net_POST_CODE1,\n    n.EMAIL AS net_EMAIL\n  FROM J09B_joined j\n  LEFT JOIN net_master n ON j.EQUNR = n.EQUNR\n)\nSELECT\n  COALESCE(sales.\"Meter Reading (MR) Doc. No.\", net.\"Meter Reading (MR) Doc. No.\") AS \"Meter Reading (MR) Doc. No.\",\n  COALESCE(sales.HAUS, net.HAUS) AS HAUS,\n  COALESCE(sales.ANLAGE, net.ANLAGE) AS ANLAGE,\n  COALESCE(sales.ME_MA_ID, net.ME_MA_ID) AS ME_MA_ID,\n  COALESCE(sales.EQUNR, net.EQUNR) AS EQUNR,\n  COALESCE(sales.HOUSE_NUM1, net.HOUSE_NUM1) AS HOUSE_NUM1,\n  COALESCE(sales.ENTSCHEIDUNG, net.ENTSCHEIDUNG) AS ENTSCHEIDUNG,\n  CASE WHEN sales.sales_TITLE IS NOT NULL THEN sales.sales_TITLE ELSE net.net_TITLE END AS TITLE,\n  CASE WHEN sales.sales_FORENAME IS NOT NULL THEN sales.sales_FORENAME ELSE net.net_FORENAME END AS FORENAME,\n  CASE WHEN sales.sales_SURNAME IS NOT NULL THEN sales.sales_SURNAME ELSE net.net_SURNAME END AS SURNAME,\n  CASE WHEN sales.sales_STREET IS NOT NULL THEN sales.sales_STREET ELSE net.net_STREET END AS STREET,\n  CASE WHEN sales.sales_STREETNO IS NOT NULL THEN sales.sales_STREETNO ELSE net.net_STREETNO END AS STREETNO,\n  CASE WHEN sales.sales_POST_CODE1 IS NOT NULL THEN sales.sales_POST_CODE1 ELSE net.net_POST_CODE1 END AS POST_CODE1,\n  CASE WHEN sales.sales_CITY1 IS NOT NULL THEN sales.sales_CITY1 ELSE net.net_CITY1 END AS CITY1,\n  CASE WHEN sales.sales_CITY2 IS NOT NULL THEN sales.sales_CITY2 ELSE net.net_CITY2 END AS CITY2,\n  CASE WHEN sales.sales_EMAIL IS NOT NULL THEN sales.sales_EMAIL ELSE net.net_EMAIL END AS EMAIL\nFROM sales\nLEFT JOIN net ON sales.EQUNR = net.EQUNR;"
            },
