        "tool_calls": [
          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH eq_counts AS (\n    SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n    FROM J09C_temp\n    GROUP BY HAUS\n),\nclassified AS (\n    SELECT t.*, ec.eq_count,\n           CASE\n               WHEN t.HOUSE_NUM1 = 0 THEN 'EVU'\n               WHEN t.HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n               WHEN t.HOUSE_NUM1 BETWEEN 900 AND 999 THEN 'EVU'\n               WHEN t.CITY1 IN ('Wiblingwerde','Breckerfeld') OR t.CITY2 IN ('Wiblingwerde','Breckerfeld') THEN 'EVU'\n               WHEN ec.eq_count >= 3 THEN 'EVU'\n               ELSE 'KSA'\n           END AS ENTSCHEIDUNG\n    FROM J09C_temp t\n    LEFT JOIN eq_counts ec ON t.HAUS = ec.HAUS\n),\njoined_eablg AS (\n    SELECT c.*, eablg.\"Meter Reading (MR) Doc. No.\", eablg.Installation\n    FROM classified c\n    LEFT JOIN eablg ON eablg.Installation = c.ANLAGE\n),\nnet_data AS (\n    SELECT n.EQUNR AS n_EQUNR, n.TITLE AS n_TITLE, n.FORENAME AS n_FORENAME, n.SURNAME AS n_SURNAME,\n           n.STREET AS n_STREET, n.STREETNO AS n_STREETNO, n.POST_CODE1 AS n_POST_CODE1,\n           n.CITY1 AS n_CITY1, n.CITY2 AS n_CITY2, n.EMAIL AS n_EMAIL\n    FROM net_master n\n),\nsales_data AS (\n    SELECT s.EQUNR AS s_EQUNR, s.TITLE AS s_TITLE, s.FORENAME AS s_FORENAME, s.SURNAME AS s_SURNAME,\n           s.STREET AS s_STREET, s.STREETNO AS s_STREETNO, s.POST_CODE1 AS s_POST_CODE1,\n           s.CITY1 AS s_CITY1, s.CITY2 AS s_CITY2, s.EMAIL AS s_EMAIL\n    FROM sales_master s\n),\ncombined AS (\n    SELECT j.\"Meter Reading (MR) Doc. No.\", j.HAUS, j.ANLAGE, j.ME_MA_ID, j.EQUNR, j.HOUSE_NUM1, j.ENTSCHEIDUNG,\n           COALESCE(s.s_TITLE, n.n_TITLE) AS TITLE,\n           COALESCE(s.s_FORENAME, n.n_FORENAME) AS FORENAME,\n           COALESCE(s.s_SURNAME, n.n_SURNAME) AS SURNAME,\n           COALESCE(s.s_STREET, n.n_STREET) AS STREET,\n           COALESCE(s.s_STREETNO, n.n_STREETNO) AS STREETNO,\n           COALESCE(s.s_POST_CODE1, n.n_POST_CODE1) AS POST_CODE1,\n           COALESCE(s.s_CITY1, n.n_CITY1) AS CITY1,\n           COALESCE(s.s_CITY2, n.n_CITY2) AS CITY2,\n           COALESCE(s.s_EMAIL, n.n_EMAIL) AS EMAIL\n    FROM joined_eablg j\n    LEFT JOIN net_data n ON n.n_EQUNR = j.EQUNR\n    LEFT JOIN sales_data s ON s.s_EQUNR = j.EQUNR\n)\nSELECT \"Meter Reading (MR) Doc. No.\", HAUS, ANLAGE, ME_MA_ID, EQUNR, HOUSE_NUM1, ENTSCHEIDUNG,\n       TITLE, FORENAME, SURNAME, STREET, STREETNO, POST_CODE1, CITY1, CITY2, EMAIL\nFROM combined;",
