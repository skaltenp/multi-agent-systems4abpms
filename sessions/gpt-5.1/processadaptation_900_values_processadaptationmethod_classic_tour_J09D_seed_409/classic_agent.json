        "tool_calls": [
          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH J09D_temp AS (\n    SELECT *\n    FROM decision_table\n    WHERE TOUR LIKE 'J09D%'\n),\nhouse_counts AS (\n    SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n    FROM J09D_temp\n    GROUP BY HAUS\n),\nclassified AS (\n    SELECT\n        j.HAUS,\n        j.ANLAGE,\n        j.ABLEINH,\n        j.TOUR,\n        j.ME_MA_ID,\n        j.CITY1,\n        j.CITY2,\n        j.HOUSE_NUM1,\n        j.POST_CODE1,\n        j.EQUNR,\n        CASE\n            WHEN j.HOUSE_NUM1 = 0 THEN 'EVU'\n            WHEN j.HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n            WHEN j.HOUSE_NUM1 BETWEEN 900 AND 999 THEN 'EVU'\n            WHEN hc.eq_count < 3 THEN 'KSA'\n            ELSE 'EVU'\n        END AS ENTSCHEIDUNG\n    FROM J09D_temp j\n    LEFT JOIN house_counts hc ON hc.HAUS = j.HAUS\n)\nSELECT\n    e.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\",\n    c.HAUS,\n    c.ANLAGE,\n    c.ME_MA_ID,\n    c.EQUNR,\n    c.HOUSE_NUM1,\n    c.ENTSCHEIDUNG,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.TITLE ELSE n.TITLE END AS TITLE,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.FORENAME ELSE n.FORENAME END AS FORENAME,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.SURNAME ELSE n.SURNAME END AS SURNAME,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.STREET ELSE n.STREET END AS STREET,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.STREETNO ELSE n.STREETNO END AS STREETNO,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.POST_CODE1 ELSE n.POST_CODE1 END AS POST_CODE1,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY1 ELSE n.CITY1 END AS CITY1,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY2 ELSE n.CITY2 END AS CITY2,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.EMAIL ELSE n.EMAIL END AS EMAIL\nFROM classified c\nLEFT JOIN eablg e\n    ON e.Installation = c.ANLAGE\nLEFT JOIN net_master n\n    ON n.EQUNR = c.EQUNR\nLEFT JOIN sales_master s\n    ON s.EQUNR = c.EQUNR;",
              "filename": "J09D"
            },
