        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TABLE J09D_enriched AS\nWITH contact_pref AS (\n    SELECT \n        dt.*, \n        -- Sales data\n        s.TITLE      AS s_TITLE,\n        s.FORENAME   AS s_FORENAME,\n        s.SURNAME    AS s_SURNAME,\n        s.STREET     AS s_STREET,\n        s.STREETNO   AS s_STREETNO,\n        s.POST_CODE1 AS s_POST_CODE1,\n        s.CITY1      AS s_CITY1,\n        s.CITY2      AS s_CITY2,\n        s.EMAIL      AS s_EMAIL,\n        -- Net data\n        n.TITLE      AS n_TITLE,\n        n.FORENAME   AS n_FORENAME,\n        n.SURNAME    AS n_SURNAME,\n        n.STREET     AS n_STREET,\n        n.STREETNO   AS n_STREETNO,\n        n.POST_CODE1 AS n_POST_CODE1,\n        n.CITY1      AS n_CITY1,\n        n.CITY2      AS n_CITY2,\n        n.EMAIL      AS n_EMAIL,\n        CASE \n            WHEN s.EQUNR IS NOT NULL THEN 1 \n            WHEN n.EQUNR IS NOT NULL THEN 0 \n            ELSE -1 \n        END AS has_sales\n    FROM J09D_temp dt\n    LEFT JOIN sales_master s ON dt.EQUNR = s.EQUNR\n    LEFT JOIN net_master   n ON dt.EQUNR = n.EQUNR\n),\nchosen_contacts AS (\n    SELECT \n        c.*,\n        CASE WHEN has_sales = 1 THEN s_TITLE ELSE n_TITLE END       AS TITLE,\n        CASE WHEN has_sales = 1 THEN s_FORENAME ELSE n_FORENAME END AS FORENAME,\n        CASE WHEN has_sales = 1 THEN s_SURNAME ELSE n_SURNAME END   AS SURNAME,\n        CASE WHEN has_sales = 1 THEN s_STREET ELSE n_STREET END     AS STREET,\n        CASE WHEN has_sales = 1 THEN s_STREETNO ELSE n_STREETNO END AS STREETNO,\n        CASE WHEN has_sales = 1 THEN s_POST_CODE1 ELSE n_POST_CODE1 END AS POST_CODE1,\n        CASE WHEN has_sales = 1 THEN s_CITY1 ELSE n_CITY1 END       AS CITY1,\n        CASE WHEN has_sales = 1 THEN s_CITY2 ELSE n_CITY2 END       AS CITY2,\n        CASE WHEN has_sales = 1 THEN s_EMAIL ELSE n_EMAIL END       AS EMAIL\n    FROM contact_pref c\n),\nwith_eablg AS (\n    SELECT \n        cc.*, \n        eablg.\"Meter Reading (MR) Doc. No.\" AS MR_Doc_No,\n        eablg.Installation\n    FROM chosen_contacts cc\n    LEFT JOIN eablg \n      ON cc.ANLAGE = eablg.Installation\n)\nSELECT *\nFROM with_eablg;"
            },
            "id": "call_R0dZYUULpl9RpLHIBcJVNzek",
