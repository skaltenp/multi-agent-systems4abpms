            "args": {
              "sqlite_command": "WITH eq_counts AS (\n    SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n    FROM J09D_temp\n    GROUP BY HAUS\n), base_decisions AS (\n    SELECT t.ROWID AS rid,\n           t.HAUS,\n           t.HOUSE_NUM1,\n           t.CITY1,\n           t.CITY2,\n           CASE WHEN ec.eq_count < 3 THEN 'KSA' ELSE 'EVU' END AS base_entscheidung\n    FROM J09D_temp t\n    LEFT JOIN eq_counts ec ON t.HAUS = ec.HAUS\n)\nUPDATE J09D_temp\nSET ENTSCHEIDUNG = (\n    SELECT CASE \n             WHEN b.HOUSE_NUM1 = 0 THEN 'EVU'\n             WHEN b.HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n             WHEN b.HOUSE_NUM1 BETWEEN 900 AND 999 THEN 'EVU'\n             WHEN (b.CITY2 LIKE '%Wiblingwerde%' OR b.CITY1 LIKE '%Wiblingwerde%') THEN 'EVU'\n             WHEN (b.CITY2 LIKE '%Breckerfeld%' OR b.CITY1 LIKE '%Breckerfeld%') THEN 'EVU'\n             ELSE b.base_entscheidung\n           END\n    FROM base_decisions b\n    WHERE b.rid = J09D_temp.ROWID\n);"
            },
