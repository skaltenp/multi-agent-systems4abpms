              "sqlite_command": "CREATE TABLE J09A_enriched AS\nWITH base AS (\n  SELECT \n    t.HAUS,\n    t.ANLAGE,\n    t.ME_MA_ID,\n    t.EQUNR,\n    t.HOUSE_NUM1,\n    t.ENTSCHEIDUNG,\n    g.\"Meter Reading (MR) Doc. No.\"\n  FROM J09A_temp t\n  LEFT JOIN eablg g ON t.ANLAGE = g.Installation\n)\nSELECT\n  b.\"Meter Reading (MR) Doc. No.\",\n  b.HAUS,\n  b.ANLAGE,\n  b.ME_MA_ID,\n  b.EQUNR,\n  b.HOUSE_NUM1,\n  b.ENTSCHEIDUNG,\n  COALESCE(s.TITLE, n.TITLE) AS TITLE,\n  COALESCE(s.FORENAME, n.FORENAME) AS FORENAME,\n  COALESCE(s.SURNAME, n.SURNAME) AS SURNAME,\n  COALESCE(s.STREET, n.STREET) AS STREET,\n  COALESCE(s.STREETNO, n.STREETNO) AS STREETNO,\n  COALESCE(s.POST_CODE1, n.POST_CODE1) AS POST_CODE1,\n  COALESCE(s.CITY1, n.CITY1) AS CITY1,\n  COALESCE(s.CITY2, n.CITY2) AS CITY2,\n  COALESCE(s.EMAIL, n.EMAIL) AS EMAIL\nFROM base b\nLEFT JOIN net_master n ON b.EQUNR = n.EQUNR\nLEFT JOIN sales_master s ON b.EQUNR = s.EQUNR;"
            },
