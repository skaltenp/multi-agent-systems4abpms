              "sql_query": "WITH joined AS (\n  SELECT\n    dt.TOUR,\n    eablg.\"Meter Reading (MR) Doc. No.\",\n    dt.HAUS,\n    dt.ANLAGE AS ANLAGE,\n    dt.ME_MA_ID,\n    dt.EQUNR,\n    dt.HOUSE_NUM1,\n    dt.ENTSCHEIDUNG,\n    COALESCE(sm.TITLE, nm.TITLE) AS TITLE,\n    COALESCE(sm.FORENAME, nm.FORENAME) AS FORENAME,\n    COALESCE(sm.SURNAME, nm.SURNAME) AS SURNAME,\n    COALESCE(sm.STREET, nm.STREET) AS STREET,\n    COALESCE(sm.STREETNO, nm.STREETNO) AS STREETNO,\n    COALESCE(sm.POST_CODE1, nm.POST_CODE1) AS POST_CODE1,\n    COALESCE(sm.CITY1, nm.CITY1) AS CITY1,\n    COALESCE(sm.CITY2, nm.CITY2) AS CITY2,\n    COALESCE(sm.EMAIL, nm.EMAIL) AS EMAIL\n  FROM J09D_temp dt\n  LEFT JOIN eablg ON eablg.Installation = dt.ANLAGE\n  LEFT JOIN net_master nm ON nm.EQUNR = dt.EQUNR\n  LEFT JOIN sales_master sm ON sm.EQUNR = dt.EQUNR\n)\nSELECT\n  \"Meter Reading (MR) Doc. No.\",\n  HAUS,\n  ANLAGE,\n  ME_MA_ID,\n  EQUNR,\n  HOUSE_NUM1,\n  ENTSCHEIDUNG,\n  TITLE,\n  FORENAME,\n  SURNAME,\n  STREET,\n  STREETNO,\n  POST_CODE1,\n  CITY1,\n  CITY2,\n  EMAIL\nFROM joined\nORDER BY TOUR, HAUS, EQUNR;",
