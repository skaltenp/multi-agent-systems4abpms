          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "WITH eq_counts AS (\n  SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n  FROM J09B_temp\n  GROUP BY HAUS\n)\nUPDATE J09B_temp\nSET ENTSCHEIDUNG = CASE\n  WHEN (\n    HOUSE_NUM1 = 0 OR\n    (HOUSE_NUM1 BETWEEN 500 AND 599) OR\n    (HOUSE_NUM1 BETWEEN 900 AND 999) OR\n    CITY1 IN ('Wiblingwerde','Breckerfeld') OR\n    CITY2 IN ('Wiblingwerde','Breckerfeld')\n  ) THEN 'EVU'\n  WHEN eq_counts.eq_count < 3 THEN 'KSA'\n  ELSE 'EVU'\nEND\nFROM eq_counts\nWHERE J09B_temp.HAUS = eq_counts.HAUS;"
            },
            "id": "call_jnpcrVvFQ6igWHAuU1ZU48bd",
            "type": "tool_call"
          }
