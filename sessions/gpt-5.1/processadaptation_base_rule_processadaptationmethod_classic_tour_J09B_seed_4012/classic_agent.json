          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "-- Recreate J09B_enriched as a persistent table with correct preference logic\nCREATE TABLE J09B_enriched AS\nSELECT \n  eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\",\n  j.HAUS,\n  j.ANLAGE,\n  j.ME_MA_ID,\n  j.EQUNR,\n  j.HOUSE_NUM1,\n  j.ENTSCHEIDUNG,\n  CASE WHEN sm.EQUNR IS NOT NULL THEN sm.TITLE ELSE nm.TITLE END AS TITLE,\n  CASE WHEN sm.EQUNR IS NOT NULL THEN sm.FORENAME ELSE nm.FORENAME END AS FORENAME,\n  CASE WHEN sm.EQUNR IS NOT NULL THEN sm.SURNAME ELSE nm.SURNAME END AS SURNAME,\n  CASE WHEN sm.EQUNR IS NOT NULL THEN sm.STREET ELSE nm.STREET END AS STREET,\n  CASE WHEN sm.EQUNR IS NOT NULL THEN sm.STREETNO ELSE nm.STREETNO END AS STREETNO,\n  CASE WHEN sm.EQUNR IS NOT NULL THEN sm.POST_CODE1 ELSE nm.POST_CODE1 END AS POST_CODE1,\n  CASE WHEN sm.EQUNR IS NOT NULL THEN sm.CITY1 ELSE nm.CITY1 END AS CITY1,\n  CASE WHEN sm.EQUNR IS NOT NULL THEN sm.CITY2 ELSE nm.CITY2 END AS CITY2,\n  CASE WHEN sm.EQUNR IS NOT NULL THEN sm.EMAIL ELSE nm.EMAIL END AS EMAIL\nFROM J09B_temp j\nLEFT JOIN eablg\n  ON eablg.Installation = j.ANLAGE\nLEFT JOIN sales_master sm\n  ON sm.EQUNR = j.EQUNR\nLEFT JOIN net_master nm\n  ON nm.EQUNR = j.EQUNR;"
            },
