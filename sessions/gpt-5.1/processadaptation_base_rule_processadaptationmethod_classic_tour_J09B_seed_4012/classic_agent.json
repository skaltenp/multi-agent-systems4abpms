        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TEMP TABLE J09B_enriched AS\nSELECT \n  eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\",\n  j.HAUS,\n  j.ANLAGE,\n  j.ME_MA_ID,\n  j.EQUNR,\n  j.HOUSE_NUM1,\n  j.ENTSCHEIDUNG,\n  /* Prefer sales_master data when available */\n  COALESCE(sm.TITLE, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.TITLE END) AS TITLE,\n  COALESCE(sm.FORENAME, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.FORENAME END) AS FORENAME,\n  COALESCE(sm.SURNAME, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.SURNAME END) AS SURNAME,\n  COALESCE(sm.STREET, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.STREET END) AS STREET,\n  COALESCE(sm.STREETNO, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.STREETNO END) AS STREETNO,\n  COALESCE(sm.POST_CODE1, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.POST_CODE1 END) AS POST_CODE1,\n  COALESCE(sm.CITY1, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.CITY1 END) AS CITY1,\n  COALESCE(sm.CITY2, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.CITY2 END) AS CITY2,\n  COALESCE(sm.EMAIL, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.EMAIL END) AS EMAIL\nFROM J09B_temp j\nLEFT JOIN eablg\n  ON eablg.Installation = j.ANLAGE\nLEFT JOIN sales_master sm\n  ON sm.EQUNR = j.EQUNR\nLEFT JOIN net_master nm\n  ON nm.EQUNR = j.EQUNR;"
            },
            "id": "call_08YLtbLH9sb8crltvfYxXxDp",
            "type": "tool_call"
          }
        ],
