              "sql_query": "WITH base AS (\n    SELECT j.*, e.\"Meter Reading (MR) Doc. No.\" AS MR_Doc_No\n    FROM J09B_temp j\n    LEFT JOIN eablg e ON j.ANLAGE = e.Installation\n),\nnet AS (\n    SELECT \n        EQUNR,\n        TITLE AS net_TITLE,\n        FORENAME AS net_FORENAME,\n        SURNAME AS net_SURNAME,\n        STREET AS net_STREET,\n        STREETNO AS net_STREETNO,\n        POST_CODE1 AS net_POST_CODE1,\n        CITY1 AS net_CITY1,\n        CITY2 AS net_CITY2,\n        EMAIL AS net_EMAIL\n    FROM net_master\n),\nsales AS (\n    SELECT \n        EQUNR,\n        TITLE AS sales_TITLE,\n        FORENAME AS sales_FORENAME,\n        SURNAME AS sales_SURNAME,\n        STREET AS sales_STREET,\n        STREETNO AS sales_STREETNO,\n        POST_CODE1 AS sales_POST_CODE1,\n        CITY1 AS sales_CITY1,\n        CITY2 AS sales_CITY2,\n        EMAIL AS sales_EMAIL\n    FROM sales_master\n),\njoined AS (\n    SELECT\n        b.MR_Doc_No AS \"Meter Reading (MR) Doc. No.\",\n        b.HAUS,\n        b.ANLAGE,\n        b.ME_MA_ID,\n        b.EQUNR,\n        b.HOUSE_NUM1,\n        b.ENTSCHEIDUNG,\n        COALESCE(s.sales_TITLE, n.net_TITLE) AS TITLE,\n        COALESCE(s.sales_FORENAME, n.net_FORENAME) AS FORENAME,\n        COALESCE(s.sales_SURNAME, n.net_SURNAME) AS SURNAME,\n        COALESCE(s.sales_STREET, n.net_STREET) AS STREET,\n        COALESCE(s.sales_STREETNO, n.net_STREETNO) AS STREETNO,\n        COALESCE(s.sales_POST_CODE1, n.net_POST_CODE1) AS POST_CODE1,\n        COALESCE(s.sales_CITY1, n.net_CITY1) AS CITY1,\n        COALESCE(s.sales_CITY2, n.net_CITY2) AS CITY2,\n        COALESCE(s.sales_EMAIL, n.net_EMAIL) AS EMAIL\n    FROM base b\n    LEFT JOIN net n ON b.EQUNR = n.EQUNR\n    LEFT JOIN sales s ON b.EQUNR = s.EQUNR\n)\nSELECT\n    \"Meter Reading (MR) Doc. No.\",\n    HAUS,\n    ANLAGE,\n    ME_MA_ID,\n    EQUNR,\n    HOUSE_NUM1,\n    ENTSCHEIDUNG,\n    TITLE,\n    FORENAME,\n    SURNAME,\n    STREET,\n    STREETNO,\n    POST_CODE1,\n    CITY1,\n    CITY2,\n    EMAIL\nFROM joined;",
