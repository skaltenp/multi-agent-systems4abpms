        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "UPDATE J09D_temp\nSET ENTSCHEIDUNG = CASE\n  WHEN HOUSE_NUM1 = 0 THEN 'EVU'\n  WHEN HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n  ELSE (\n    CASE\n      WHEN (\n        SELECT COUNT(DISTINCT EQUNR)\n        FROM J09D_temp jt2\n        WHERE jt2.HAUS = J09D_temp.HAUS\n      ) < 3 THEN 'KSA'\n      ELSE 'EVU'\n    END\n  )\n;"
