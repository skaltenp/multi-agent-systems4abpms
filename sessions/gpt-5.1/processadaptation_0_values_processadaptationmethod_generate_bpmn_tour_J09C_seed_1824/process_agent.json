              "sql_query": "WITH classified AS (\n  SELECT t.*\n  FROM J09C_temp t\n),\njoined_eablg AS (\n  SELECT c.*, eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\"\n  FROM classified c\n  LEFT JOIN eablg ON c.ANLAGE = eablg.Installation\n),\njoined_customers AS (\n  SELECT\n    j.\"Meter Reading (MR) Doc. No.\",\n    j.HAUS,\n    j.ANLAGE,\n    j.ME_MA_ID,\n    j.EQUNR,\n    j.HOUSE_NUM1,\n    j.ENTSCHEIDUNG,\n    COALESCE(NULLIF(sm.TITLE, ''), nm.TITLE) AS TITLE,\n    COALESCE(NULLIF(sm.FORENAME, ''), nm.FORENAME) AS FORENAME,\n    COALESCE(NULLIF(sm.SURNAME, ''), nm.SURNAME) AS SURNAME,\n    COALESCE(NULLIF(sm.STREET, ''), nm.STREET) AS STREET,\n    COALESCE(NULLIF(sm.STREETNO, ''), nm.STREETNO) AS STREETNO,\n    COALESCE(NULLIF(sm.POST_CODE1, ''), nm.POST_CODE1) AS POST_CODE1,\n    COALESCE(NULLIF(sm.CITY1, ''), nm.CITY1) AS CITY1,\n    COALESCE(NULLIF(sm.CITY2, ''), nm.CITY2) AS CITY2,\n    COALESCE(NULLIF(sm.EMAIL, ''), nm.EMAIL) AS EMAIL\n  FROM joined_eablg j\n  LEFT JOIN net_master nm ON j.EQUNR = nm.EQUNR\n  LEFT JOIN sales_master sm ON j.EQUNR = sm.EQUNR\n)\nSELECT\n  \"Meter Reading (MR) Doc. No.\",\n  HAUS,\n  ANLAGE,\n  ME_MA_ID,\n  EQUNR,\n  HOUSE_NUM1,\n  ENTSCHEIDUNG,\n  TITLE,\n  FORENAME,\n  SURNAME,\n  STREET,\n  STREETNO,\n  POST_CODE1,\n  CITY1,\n  CITY2,\n  EMAIL\nFROM joined_customers;",
              "filename": "J09C"
