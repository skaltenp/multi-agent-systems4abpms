        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TABLE J09C_enriched AS\nWITH base AS (\n  SELECT \n    j.\"HAUS\",\n    j.\"ANLAGE\" AS ANLAGE,\n    j.\"ME_MA_ID\" AS ME_MA_ID,\n    j.\"EQUNR\" AS EQUNR,\n    j.\"HOUSE_NUM1\" AS HOUSE_NUM1,\n    j.\"ENTSCHEIDUNG\" AS ENTSCHEIDUNG,\n    e.\"Meter Reading (MR) Doc. No.\" AS MR_DOC_NO,\n    j.ROWID AS row_id\n  FROM J09C_temp j\n  LEFT JOIN eablg e\n    ON e.\"Installation\" = j.\"ANLAGE\"\n),\nnet AS (\n  SELECT \n    EQUNR,\n    TITLE AS net_TITLE,\n    FORENAME AS net_FORENAME,\n    SURNAME AS net_SURNAME,\n    STREET AS net_STREET,\n    STREETNO AS net_STREETNO,\n    POST_CODE1 AS net_POST_CODE1,\n    CITY1 AS net_CITY1,\n    CITY2 AS net_CITY2,\n    EMAIL AS net_EMAIL\n  FROM net_master\n),\nsales AS (\n  SELECT \n    EQUNR,\n    TITLE AS sales_TITLE,\n    FORENAME AS sales_FORENAME,\n    SURNAME AS sales_SURNAME,\n    STREET AS sales_STREET,\n    STREETNO AS sales_STREETNO,\n    POST_CODE1 AS sales_POST_CODE1,\n    CITY1 AS sales_CITY1,\n    CITY2 AS sales_CITY2,\n    EMAIL AS sales_EMAIL\n  FROM sales_master\n)\nSELECT\n  b.MR_DOC_NO AS \"Meter Reading (MR) Doc. No.\",\n  b.HAUS AS \"HAUS\",\n  b.ANLAGE AS \"ANLAGE\",\n  b.ME_MA_ID AS \"ME_MA_ID\",\n  b.EQUNR AS \"EQUNR\",\n  b.HOUSE_NUM1 AS \"HOUSE_NUM1\",\n  b.ENTSCHEIDUNG AS \"ENTSCHEIDUNG\",\n  -- Prefer sales data; if present, use sales and null out net fields in final projection\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_TITLE ELSE n.net_TITLE END AS \"TITLE\",\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_FORENAME ELSE n.net_FORENAME END AS \"FORENAME\",\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_SURNAME ELSE n.net_SURNAME END AS \"SURNAME\",\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_STREET ELSE n.net_STREET END AS \"STREET\",\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_STREETNO ELSE n.net_STREETNO END AS \"STREETNO\",\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_POST_CODE1 ELSE n.net_POST_CODE1 END AS \"POST_CODE1\",\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_CITY1 ELSE n.net_CITY1 END AS \"CITY1\",\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_CITY2 ELSE n.net_CITY2 END AS \"CITY2\",\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_EMAIL ELSE n.net_EMAIL END AS \"EMAIL\"\nFROM base b\nLEFT JOIN net n ON n.EQUNR = b.EQUNR\nLEFT JOIN sales s ON s.EQUNR = b.EQUNR;"
            },
            "id": "call_vyEOoNWy8hEjz8eyLhQL1x7x",
            "type": "tool_call"
          }
