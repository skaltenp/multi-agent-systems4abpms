            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH classified AS (\n    SELECT t.*\n    FROM J09B_temp t\n),\ncontact AS (\n    SELECT \n        COALESCE(s.EQUNR, n.EQUNR) AS EQUNR,\n        s.TITLE AS SALES_TITLE,\n        s.FORENAME AS SALES_FORENAME,\n        s.SURNAME AS SALES_SURNAME,\n        s.STREET AS SALES_STREET,\n        s.STREETNO AS SALES_STREETNO,\n        s.POST_CODE1 AS SALES_POST_CODE1,\n        s.CITY1 AS SALES_CITY1,\n        s.CITY2 AS SALES_CITY2,\n        s.EMAIL AS SALES_EMAIL,\n        n.TITLE AS NET_TITLE,\n        n.FORENAME AS NET_FORENAME,\n        n.SURNAME AS NET_SURNAME,\n        n.STREET AS NET_STREET,\n        n.STREETNO AS NET_STREETNO,\n        n.POST_CODE1 AS NET_POST_CODE1,\n        n.CITY1 AS NET_CITY1,\n        n.CITY2 AS NET_CITY2,\n        n.EMAIL AS NET_EMAIL\n    FROM net_master n\n    FULL OUTER JOIN sales_master s ON n.EQUNR = s.EQUNR\n),\npreferred_contact AS (\n    SELECT\n        EQUNR,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN SALES_TITLE ELSE NET_TITLE END AS TITLE,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN SALES_FORENAME ELSE NET_FORENAME END AS FORENAME,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN SALES_SURNAME ELSE NET_SURNAME END AS SURNAME,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN SALES_STREET ELSE NET_STREET END AS STREET,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN SALES_STREETNO ELSE NET_STREETNO END AS STREETNO,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN SALES_POST_CODE1 ELSE NET_POST_CODE1 END AS POST_CODE1,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN SALES_CITY1 ELSE NET_CITY1 END AS CITY1,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN SALES_CITY2 ELSE NET_CITY2 END AS CITY2,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN SALES_EMAIL ELSE NET_EMAIL END AS EMAIL,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN NULL ELSE NET_TITLE END AS NET_TITLE_OUT,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN NULL ELSE NET_FORENAME END AS NET_FORENAME_OUT,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN NULL ELSE NET_SURNAME END AS NET_SURNAME_OUT,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN NULL ELSE NET_STREET END AS NET_STREET_OUT,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN NULL ELSE NET_STREETNO END AS NET_STREETNO_OUT,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN NULL ELSE NET_POST_CODE1 END AS NET_POST_CODE1_OUT,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN NULL ELSE NET_CITY1 END AS NET_CITY1_OUT,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN NULL ELSE NET_CITY2 END AS NET_CITY2_OUT,\n        CASE WHEN SALES_TITLE IS NOT NULL THEN NULL ELSE NET_EMAIL END AS NET_EMAIL_OUT\n    FROM contact\n),\njoined AS (\n    SELECT \n        eablg.\"Meter Reading (MR) Doc. No.\",\n        c.HAUS,\n        c.ANLAGE,\n        c.ME_MA_ID,\n        c.EQUNR,\n        c.HOUSE_NUM1,\n        c.ENTSCHEIDUNG,\n        pc.TITLE,\n        pc.FORENAME,\n        pc.SURNAME,\n        pc.STREET,\n        pc.STREETNO,\n        pc.POST_CODE1,\n        pc.CITY1,\n        pc.CITY2,\n        pc.EMAIL\n    FROM classified c\n    LEFT JOIN eablg ON eablg.Installation = c.ANLAGE\n    LEFT JOIN preferred_contact pc ON pc.EQUNR = c.EQUNR\n)\nSELECT * FROM joined;",
