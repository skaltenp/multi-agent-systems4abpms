        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "WITH eq_counts AS (\n  SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n  FROM J09A_temp\n  GROUP BY HAUS\n)\nUPDATE J09A_temp\nSET ENTSCHEIDUNG = CASE\n  WHEN HOUSE_NUM1 = 0 THEN 'EVU'\n  WHEN HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n  WHEN eq_count < 3 THEN 'KSA'\n  ELSE 'EVU'\nEND\nFROM eq_counts\nWHERE J09A_temp.HAUS = eq_counts.HAUS;"
