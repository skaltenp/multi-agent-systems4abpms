        "id": "lc_run--019cf1d2-82f3-7b32-ab8c-71f00aacc63b-0",
        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "WITH eq_counts AS (\n  SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n  FROM J09B_temp\n  GROUP BY HAUS\n)\nUPDATE J09B_temp\nSET ENTSCHEIDUNG = CASE\n  WHEN ec.eq_count < 3 THEN 'KSA'\n  ELSE 'EVU'\nEND\nFROM eq_counts ec\nWHERE J09B_temp.HAUS = ec.HAUS;"
            },
