              "sql_query": "WITH base AS (\n    SELECT \n        d.\"Meter Reading (MR) Doc. No.\",\n        d.HAUS,\n        d.ANLAGE,\n        d.ME_MA_ID,\n        d.EQUNR,\n        d.HOUSE_NUM1,\n        d.ENTSCHEIDUNG,\n        COALESCE(s.TITLE, n.TITLE) AS TITLE_source,\n        COALESCE(s.FORENAME, n.FORENAME) AS FORENAME_source,\n        COALESCE(s.SURNAME, n.SURNAME) AS SURNAME_source,\n        COALESCE(s.STREET, n.STREET) AS STREET_source,\n        COALESCE(s.STREETNO, n.STREETNO) AS STREETNO_source,\n        COALESCE(s.POST_CODE1, n.POST_CODE1) AS POST_CODE1_source,\n        COALESCE(s.CITY1, n.CITY1) AS CITY1_source,\n        COALESCE(s.CITY2, n.CITY2) AS CITY2_source,\n        COALESCE(s.EMAIL, n.EMAIL) AS EMAIL_source\n    FROM J09C_temp d\n    LEFT JOIN eablg e ON e.Installation = d.ANLAGE\n    LEFT JOIN net_master n ON n.EQUNR = d.EQUNR\n    LEFT JOIN sales_master s ON s.EQUNR = d.EQUNR\n),\nfinal AS (\n    SELECT\n        \"Meter Reading (MR) Doc. No.\",\n        HAUS,\n        ANLAGE,\n        ME_MA_ID,\n        EQUNR,\n        HOUSE_NUM1,\n        ENTSCHEIDUNG,\n        CASE WHEN s.EQUNR IS NOT NULL THEN s.TITLE ELSE n.TITLE END AS TITLE,\n        CASE WHEN s.EQUNR IS NOT NULL THEN s.FORENAME ELSE n.FORENAME END AS FORENAME,\n        CASE WHEN s.EQUNR IS NOT NULL THEN s.SURNAME ELSE n.SURNAME END AS SURNAME,\n        CASE WHEN s.EQUNR IS NOT NULL THEN s.STREET ELSE n.STREET END AS STREET,\n        CASE WHEN s.EQUNR IS NOT NULL THEN s.STREETNO ELSE n.STREETNO END AS STREETNO,\n        CASE WHEN s.EQUNR IS NOT NULL THEN s.POST_CODE1 ELSE n.POST_CODE1 END AS POST_CODE1,\n        CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY1 ELSE n.CITY1 END AS CITY1,\n        CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY2 ELSE n.CITY2 END AS CITY2,\n        CASE WHEN s.EQUNR IS NOT NULL THEN s.EMAIL ELSE n.EMAIL END AS EMAIL\n    FROM J09C_temp d\n    LEFT JOIN eablg e ON e.Installation = d.ANLAGE\n    LEFT JOIN net_master n ON n.EQUNR = d.EQUNR\n    LEFT JOIN sales_master s ON s.EQUNR = d.EQUNR\n)\nSELECT\n    \"Meter Reading (MR) Doc. No.\",\n    HAUS,\n    ANLAGE,\n    ME_MA_ID,\n    EQUNR,\n    HOUSE_NUM1,\n    ENTSCHEIDUNG,\n    TITLE,\n    FORENAME,\n    SURNAME,\n    STREET,\n    STREETNO,\n    POST_CODE1,\n    CITY1,\n    CITY2,\n    EMAIL\nFROM final;",
