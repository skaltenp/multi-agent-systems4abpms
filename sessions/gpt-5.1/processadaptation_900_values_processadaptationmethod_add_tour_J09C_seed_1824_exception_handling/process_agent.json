        "tool_calls": [
          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH base AS (\n  SELECT d.*, e.\"Meter Reading (MR) Doc. No.\"\n  FROM J09C_temp d\n  LEFT JOIN eabl e ON d.EQUNR = e.EQUNR\n  LEFT JOIN eablg g ON e.\"Meter Reading (MR) Doc. No.\" = g.\"Meter Reading (MR) Doc. No.\"\n)\n, joined AS (\n  SELECT b.*, \n         n.TITLE AS net_TITLE, n.FORENAME AS net_FORENAME, n.SURNAME AS net_SURNAME,\n         n.STREET AS net_STREET, n.STREETNO AS net_STREETNO, n.CITY1 AS net_CITY1,\n         n.CITY2 AS net_CITY2, n.POST_CODE1 AS net_POST_CODE1, n.EMAIL AS net_EMAIL,\n         s.TITLE AS sales_TITLE, s.FORENAME AS sales_FORENAME, s.SURNAME AS sales_SURNAME,\n         s.STREET AS sales_STREET, s.STREETNO AS sales_STREETNO, s.CITY1 AS sales_CITY1,\n         s.CITY2 AS sales_CITY2, s.POST_CODE1 AS sales_POST_CODE1, s.EMAIL AS sales_EMAIL\n  FROM base b\n  LEFT JOIN net_master n ON b.EQUNR = n.EQUNR\n  LEFT JOIN sales_master s ON b.EQUNR = s.EQUNR\n)\nSELECT \n  \"Meter Reading (MR) Doc. No.\",\n  HAUS,\n  ANLAGE,\n  ME_MA_ID,\n  EQUNR,\n  HOUSE_NUM1,\n  ENTSCHEIDUNG,\n  COALESCE(sales_TITLE, net_TITLE) AS TITLE,\n  COALESCE(sales_FORENAME, net_FORENAME) AS FORENAME,\n  COALESCE(sales_SURNAME, net_SURNAME) AS SURNAME,\n  COALESCE(sales_STREET, net_STREET) AS STREET,\n  COALESCE(sales_STREETNO, net_STREETNO) AS STREETNO,\n  COALESCE(sales_POST_CODE1, net_POST_CODE1) AS POST_CODE1,\n  COALESCE(sales_CITY1, net_CITY1) AS CITY1,\n  COALESCE(sales_CITY2, net_CITY2) AS CITY2,\n  COALESCE(sales_EMAIL, net_EMAIL) AS EMAIL\nFROM joined;",
              "filename": "J09C"
            },
            "id": "call_eAn3FC7GPMx2CFTWv7rym1hG",
            "type": "tool_call"
          }
        ],
