            "args": {
              "sqlite_command": "CREATE TEMP VIEW J09D_enriched AS\nWITH base AS (\n  SELECT \n    d.[Meter Reading (MR) Doc. No.],\n    d.HAUS,\n    d.ANLAGE,\n    d.ME_MA_ID,\n    d.EQUNR,\n    d.HOUSE_NUM1,\n    d.ENTSCHEIDUNG\n  FROM J09D_temp d\n  LEFT JOIN eablg e\n    ON d.ANLAGE = e.Installation\n)\nSELECT \n  b.[Meter Reading (MR) Doc. No.],\n  b.HAUS,\n  b.ANLAGE,\n  b.ME_MA_ID,\n  b.EQUNR,\n  b.HOUSE_NUM1,\n  b.ENTSCHEIDUNG,\n  COALESCE(s.TITLE, n.TITLE) AS TITLE,\n  COALESCE(s.FORENAME, n.FORENAME) AS FORENAME,\n  COALESCE(s.SURNAME, n.SURNAME) AS SURNAME,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.STREET ELSE n.STREET END AS STREET,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.STREETNO ELSE n.STREETNO END AS STREETNO,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.POST_CODE1 ELSE n.POST_CODE1 END AS POST_CODE1,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY1 ELSE n.CITY1 END AS CITY1,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY2 ELSE n.CITY2 END AS CITY2,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.EMAIL ELSE n.EMAIL END AS EMAIL\nFROM base b\nLEFT JOIN net_master n\n  ON b.EQUNR = n.EQUNR\nLEFT JOIN sales_master s\n  ON b.EQUNR = s.EQUNR;"
            },
            "id": "call_PU6zbfb60lS9a3Rp9HwEOYsR",
