        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "WITH eq_counts AS (\n  SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n  FROM J09D_temp\n  GROUP BY HAUS\n)\nUPDATE J09D_temp\nSET ENTSCHEIDUNG = CASE\n  WHEN ec.eq_count < 3 THEN 'KSA'\n  ELSE 'EVU'\nEND\nFROM eq_counts ec\nWHERE J09D_temp.HAUS = ec.HAUS;"
