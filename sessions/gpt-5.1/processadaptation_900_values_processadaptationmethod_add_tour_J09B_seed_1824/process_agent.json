              "sqlite_command": "CREATE TABLE IF NOT EXISTS J09B_joined AS\nSELECT dt.\"Meter Reading (MR) Doc. No.\", dt.HAUS, dt.ANLAGE, dt.ME_MA_ID, dt.EQUNR, dt.HOUSE_NUM1,\n       dt.ENTSCHEIDUNG,\n       nm.TITLE AS nm_TITLE, nm.FORENAME AS nm_FORENAME, nm.SURNAME AS nm_SURNAME,\n       nm.STREET AS nm_STREET, nm.STREETNO AS nm_STREETNO, nm.POST_CODE1 AS nm_POST_CODE1,\n       nm.CITY1 AS nm_CITY1, nm.CITY2 AS nm_CITY2, nm.EMAIL AS nm_EMAIL,\n       sm.TITLE AS sm_TITLE, sm.FORENAME AS sm_FORENAME, sm.SURNAME AS sm_SURNAME,\n       sm.STREET AS sm_STREET, sm.STREETNO AS sm_STREETNO, sm.POST_CODE1 AS sm_POST_CODE1,\n       sm.CITY1 AS sm_CITY1, sm.CITY2 AS sm_CITY2, sm.EMAIL AS sm_EMAIL\nFROM (\n  SELECT jt.*, eablg.\"Meter Reading (MR) Doc. No.\"\n  FROM J09B_temp jt\n  LEFT JOIN eablg ON jt.ANLAGE = eablg.Installation\n) dt\nLEFT JOIN net_master nm ON dt.EQUNR = nm.EQUNR\nLEFT JOIN sales_master sm ON dt.EQUNR = sm.EQUNR;"
