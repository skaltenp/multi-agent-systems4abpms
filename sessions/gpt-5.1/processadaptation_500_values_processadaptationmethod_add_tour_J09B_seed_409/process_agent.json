            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TABLE J09B_joined AS\nSELECT dt.[Meter Reading (MR) Doc. No.], dt.HAUS, dt.ANLAGE, dt.ME_MA_ID, dt.EQUNR, dt.HOUSE_NUM1, dt.ENTSCHEIDUNG,\n       nm.TITLE AS nm_TITLE, nm.FORENAME AS nm_FORENAME, nm.SURNAME AS nm_SURNAME, nm.STREET AS nm_STREET, nm.STREETNO AS nm_STREETNO,\n       nm.POST_CODE1 AS nm_POST_CODE1, nm.CITY1 AS nm_CITY1, nm.CITY2 AS nm_CITY2, nm.EMAIL AS nm_EMAIL,\n       sm.TITLE AS sm_TITLE, sm.FORENAME AS sm_FORENAME, sm.SURNAME AS sm_SURNAME, sm.STREET AS sm_STREET, sm.STREETNO AS sm_STREETNO,\n       sm.POST_CODE1 AS sm_POST_CODE1, sm.CITY1 AS sm_CITY1, sm.CITY2 AS sm_CITY2, sm.EMAIL AS sm_EMAIL\nFROM (\n   SELECT j.*, eablg.[Meter Reading (MR) Doc. No.]\n   FROM J09B_temp j\n   LEFT JOIN eablg ON j.ANLAGE = eablg.Installation\n) dt\nLEFT JOIN net_master nm ON dt.EQUNR = nm.EQUNR\nLEFT JOIN sales_master sm ON dt.EQUNR = sm.EQUNR;"
