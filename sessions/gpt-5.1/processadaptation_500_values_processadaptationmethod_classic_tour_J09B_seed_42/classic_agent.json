        "tool_calls": [
          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH base AS (\n    SELECT \n        j.ME_MA_ID,\n        j.ANLAGE,\n        j.HAUS,\n        j.EQUNR,\n        j.HOUSE_NUM1,\n        j.ENTSCHEIDUNG\n    FROM J09B_temp j\n),\n\njoined_eablg AS (\n    SELECT \n        b.*,\n        e.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\"\n    FROM base b\n    LEFT JOIN eablg e\n      ON e.Installation = b.ANLAGE\n),\n\nnet AS (\n    SELECT \n        n.EQUNR,\n        n.TITLE AS net_TITLE,\n        n.FORENAME AS net_FORENAME,\n        n.SURNAME AS net_SURNAME,\n        n.STREET AS net_STREET,\n        n.STREETNO AS net_STREETNO,\n        n.POST_CODE1 AS net_POST_CODE1,\n        n.CITY1 AS net_CITY1,\n        n.CITY2 AS net_CITY2,\n        n.EMAIL AS net_EMAIL\n    FROM net_master n\n),\n\nsales AS (\n    SELECT \n        s.EQUNR,\n        s.TITLE AS sales_TITLE,\n        s.FORENAME AS sales_FORENAME,\n        s.SURNAME AS sales_SURNAME,\n        s.STREET AS sales_STREET,\n        s.STREETNO AS sales_STREETNO,\n        s.POST_CODE1 AS sales_POST_CODE1,\n        s.CITY1 AS sales_CITY1,\n        s.CITY2 AS sales_CITY2,\n        s.EMAIL AS sales_EMAIL\n    FROM sales_master s\n)\n\nSELECT\n    je.\"Meter Reading (MR) Doc. No.\",\n    je.HAUS,\n    je.ANLAGE,\n    je.ME_MA_ID,\n    je.EQUNR,\n    je.HOUSE_NUM1,\n    je.ENTSCHEIDUNG,\n    -- Prefer sales data when available; otherwise use net data. When sales exists, net fields should be empty.\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_TITLE ELSE n.net_TITLE END AS TITLE,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_FORENAME ELSE n.net_FORENAME END AS FORENAME,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_SURNAME ELSE n.net_SURNAME END AS SURNAME,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_STREET ELSE n.net_STREET END AS STREET,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_STREETNO ELSE n.net_STREETNO END AS STREETNO,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_POST_CODE1 ELSE n.net_POST_CODE1 END AS POST_CODE1,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_CITY1 ELSE n.net_CITY1 END AS CITY1,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_CITY2 ELSE n.net_CITY2 END AS CITY2,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_EMAIL ELSE n.net_EMAIL END AS EMAIL\nFROM joined_eablg je\nLEFT JOIN net n\n  ON je.EQUNR = n.EQUNR\nLEFT JOIN sales s\n  ON je.EQUNR = s.EQUNR;",
