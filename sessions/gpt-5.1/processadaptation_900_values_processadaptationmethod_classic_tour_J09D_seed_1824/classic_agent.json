        "tool_calls": [
          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH eq_counts AS (\n    SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n    FROM J09D_temp\n    GROUP BY HAUS\n),\nclassified AS (\n    SELECT t.*, \n           CASE\n               WHEN HOUSE_NUM1 = 0 THEN 'EVU'\n               WHEN HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n               WHEN HOUSE_NUM1 BETWEEN 900 AND 999 THEN 'EVU'\n               WHEN eq_counts.eq_count < 3 THEN 'KSA'\n               ELSE 'EVU'\n           END AS ENTSCHEIDUNG\n    FROM J09D_temp t\n    LEFT JOIN eq_counts ON t.HAUS = eq_counts.HAUS\n),\njoined_eablg AS (\n    SELECT c.*, eablg.\"Meter Reading (MR) Doc. No.\" AS MR_Doc_No, eablg.Installation\n    FROM classified c\n    LEFT JOIN eablg ON c.ANLAGE = eablg.Installation\n),\nnet_data AS (\n    SELECT j.*, \n           n.TITLE AS net_TITLE,\n           n.FORENAME AS net_FORENAME,\n           n.SURNAME AS net_SURNAME,\n           n.STREET AS net_STREET,\n           n.STREETNO AS net_STREETNO,\n           n.POST_CODE1 AS net_POST_CODE1,\n           n.CITY1 AS net_CITY1,\n           n.CITY2 AS net_CITY2,\n           n.EMAIL AS net_EMAIL\n    FROM joined_eablg j\n    LEFT JOIN net_master n ON j.EQUNR = n.EQUNR\n),\nsales_data AS (\n    SELECT n.*, \n           s.TITLE AS sales_TITLE,\n           s.FORENAME AS sales_FORENAME,\n           s.SURNAME AS sales_SURNAME,\n           s.STREET AS sales_STREET,\n           s.STREETNO AS sales_STREETNO,\n           s.POST_CODE1 AS sales_POST_CODE1,\n           s.CITY1 AS sales_CITY1,\n           s.CITY2 AS sales_CITY2,\n           s.EMAIL AS sales_EMAIL\n    FROM net_data n\n    LEFT JOIN sales_master s ON n.EQUNR = s.EQUNR\n)\nSELECT \n    j.MR_Doc_No AS \"Meter Reading (MR) Doc. No.\",\n    j.HAUS,\n    j.ANLAGE,\n    j.ME_MA_ID,\n    j.EQUNR,\n    j.HOUSE_NUM1,\n    j.ENTSCHEIDUNG,\n    CASE WHEN j.sales_TITLE IS NOT NULL THEN j.sales_TITLE ELSE j.net_TITLE END AS TITLE,\n    CASE WHEN j.sales_FORENAME IS NOT NULL THEN j.sales_FORENAME ELSE j.net_FORENAME END AS FORENAME,\n    CASE WHEN j.sales_SURNAME IS NOT NULL THEN j.sales_SURNAME ELSE j.net_SURNAME END AS SURNAME,\n    CASE WHEN j.sales_STREET IS NOT NULL THEN j.sales_STREET ELSE j.net_STREET END AS STREET,\n    CASE WHEN j.sales_STREETNO IS NOT NULL THEN j.sales_STREETNO ELSE j.net_STREETNO END AS STREETNO,\n    CASE WHEN j.sales_POST_CODE1 IS NOT NULL THEN j.sales_POST_CODE1 ELSE j.net_POST_CODE1 END AS POST_CODE1,\n    CASE WHEN j.sales_CITY1 IS NOT NULL THEN j.sales_CITY1 ELSE j.net_CITY1 END AS CITY1,\n    CASE WHEN j.sales_CITY2 IS NOT NULL THEN j.sales_CITY2 ELSE j.net_CITY2 END AS CITY2,\n    CASE WHEN j.sales_EMAIL IS NOT NULL THEN j.sales_EMAIL ELSE j.net_EMAIL END AS EMAIL\nFROM sales_data j;",
              "filename": "J09D"
            },
            "id": "call_WoeILBqvkivSoi6047GibOXZ",
            "type": "tool_call"
          }
