              "sql_query": "WITH base AS (\n    SELECT \n        j.\"HAUS\",\n        j.\"ANLAGE\",\n        j.\"ME_MA_ID\",\n        j.\"EQUNR\",\n        j.\"HOUSE_NUM1\",\n        j.\"ENTSCHEIDUNG\",\n        e.\"Meter Reading (MR) Doc. No.\"\n    FROM J09D_temp j\n    LEFT JOIN eablg e\n        ON e.\"Installation\" = j.\"ANLAGE\"\n),\nnet AS (\n    SELECT \n        b.*,\n        n.TITLE AS net_TITLE,\n        n.FORENAME AS net_FORENAME,\n        n.SURNAME AS net_SURNAME,\n        n.STREET AS net_STREET,\n        n.STREETNO AS net_STREETNO,\n        n.POST_CODE1 AS net_POST_CODE1,\n        n.CITY1 AS net_CITY1,\n        n.CITY2 AS net_CITY2,\n        n.EMAIL AS net_EMAIL\n    FROM base b\n    LEFT JOIN net_master n\n        ON n.EQUNR = b.EQUNR\n),\nsales AS (\n    SELECT \n        n.*,\n        s.TITLE AS sales_TITLE,\n        s.FORENAME AS sales_FORENAME,\n        s.SURNAME AS sales_SURNAME,\n        s.STREET AS sales_STREET,\n        s.STREETNO AS sales_STREETNO,\n        s.POST_CODE1 AS sales_POST_CODE1,\n        s.CITY1 AS sales_CITY1,\n        s.CITY2 AS sales_CITY2,\n        s.EMAIL AS sales_EMAIL\n    FROM net n\n    LEFT JOIN sales_master s\n        ON s.EQUNR = n.EQUNR\n)\nSELECT\n    \"Meter Reading (MR) Doc. No.\",\n    HAUS,\n    ANLAGE,\n    ME_MA_ID,\n    EQUNR,\n    HOUSE_NUM1,\n    ENTSCHEIDUNG,\n    -- Prefer sales_* fields when present; otherwise use net_* fields\n    CASE WHEN sales_TITLE IS NOT NULL THEN sales_TITLE ELSE net_TITLE END AS TITLE,\n    CASE WHEN sales_FORENAME IS NOT NULL THEN sales_FORENAME ELSE net_FORENAME END AS FORENAME,\n    CASE WHEN sales_SURNAME IS NOT NULL THEN sales_SURNAME ELSE net_SURNAME END AS SURNAME,\n    CASE WHEN sales_STREET IS NOT NULL THEN sales_STREET ELSE net_STREET END AS STREET,\n    CASE WHEN sales_STREETNO IS NOT NULL THEN sales_STREETNO ELSE net_STREETNO END AS STREETNO,\n    CASE WHEN sales_POST_CODE1 IS NOT NULL THEN sales_POST_CODE1 ELSE net_POST_CODE1 END AS POST_CODE1,\n    CASE WHEN sales_CITY1 IS NOT NULL THEN sales_CITY1 ELSE net_CITY1 END AS CITY1,\n    CASE WHEN sales_CITY2 IS NOT NULL THEN sales_CITY2 ELSE net_CITY2 END AS CITY2,\n    CASE WHEN sales_EMAIL IS NOT NULL THEN sales_EMAIL ELSE net_EMAIL END AS EMAIL\nFROM sales;",
