          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TABLE J09C_enriched AS\nWITH base AS (\n    SELECT t.*, eablg.\"Meter Reading (MR) Doc. No.\", eablg.Installation\n    FROM J09C_temp t\n    LEFT JOIN eablg ON eablg.Installation = t.ANLAGE\n),\nnet AS (\n    SELECT EQUNR,\n           TITLE AS net_TITLE,\n           FORENAME AS net_FORENAME,\n           SURNAME AS net_SURNAME,\n           STREET AS net_STREET,\n           STREETNO AS net_STREETNO,\n           POST_CODE1 AS net_POST_CODE1,\n           CITY1 AS net_CITY1,\n           CITY2 AS net_CITY2,\n           EMAIL AS net_EMAIL\n    FROM net_master\n),\nsales AS (\n    SELECT EQUNR,\n           TITLE AS sales_TITLE,\n           FORENAME AS sales_FORENAME,\n           SURNAME AS sales_SURNAME,\n           STREET AS sales_STREET,\n           STREETNO AS sales_STREETNO,\n           POST_CODE1 AS sales_POST_CODE1,\n           CITY1 AS sales_CITY1,\n           CITY2 AS sales_CITY2,\n           EMAIL AS sales_EMAIL\n    FROM sales_master\n)\nSELECT\n    base.\"Meter Reading (MR) Doc. No.\",\n    base.HAUS,\n    base.ANLAGE,\n    base.ME_MA_ID,\n    base.EQUNR,\n    base.HOUSE_NUM1,\n    base.ENTSCHEIDUNG,\n    CASE WHEN sales.sales_TITLE IS NOT NULL THEN sales.sales_TITLE ELSE net.net_TITLE END AS TITLE,\n    CASE WHEN sales.sales_FORENAME IS NOT NULL THEN sales.sales_FORENAME ELSE net.net_FORENAME END AS FORENAME,\n    CASE WHEN sales.sales_SURNAME IS NOT NULL THEN sales.sales_SURNAME ELSE net.net_SURNAME END AS SURNAME,\n    CASE WHEN sales.sales_STREET IS NOT NULL THEN sales.sales_STREET ELSE net.net_STREET END AS STREET,\n    CASE WHEN sales.sales_STREETNO IS NOT NULL THEN sales.sales_STREETNO ELSE net.net_STREETNO END AS STREETNO,\n    CASE WHEN sales.sales_POST_CODE1 IS NOT NULL THEN sales.sales_POST_CODE1 ELSE net.net_POST_CODE1 END AS POST_CODE1,\n    CASE WHEN sales.sales_CITY1 IS NOT NULL THEN sales.sales_CITY1 ELSE net.net_CITY1 END AS CITY1,\n    CASE WHEN sales.sales_CITY2 IS NOT NULL THEN sales.sales_CITY2 ELSE net.net_CITY2 END AS CITY2,\n    CASE WHEN sales.sales_EMAIL IS NOT NULL THEN sales.sales_EMAIL ELSE net.net_EMAIL END AS EMAIL\nFROM base\nLEFT JOIN net ON net.EQUNR = base.EQUNR\nLEFT JOIN sales ON sales.EQUNR = base.EQUNR;"
            },
