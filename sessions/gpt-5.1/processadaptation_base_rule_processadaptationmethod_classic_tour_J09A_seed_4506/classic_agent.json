            "args": {
              "sql_query": "WITH sales AS (\n  SELECT \n    d.[HAUS],\n    d.[ANLAGE],\n    d.[ME_MA_ID],\n    d.[EQUNR],\n    d.[HOUSE_NUM1],\n    d.[ENTSCHEIDUNG],\n    s.TITLE,\n    s.FORENAME,\n    s.SURNAME,\n    s.STREET,\n    s.STREETNO,\n    s.POST_CODE1,\n    s.CITY1,\n    s.CITY2,\n    s.EMAIL,\n    eablg.[Meter Reading (MR) Doc. No.]\n  FROM J09A_temp d\n  LEFT JOIN eabl eab ON d.EQUNR = eab.EQUNR\n  LEFT JOIN eablg ON eab.[Meter Reading (MR) Doc. No.] = eablg.[Meter Reading (MR) Doc. No.]\n  LEFT JOIN sales_master s ON d.EQUNR = s.EQUNR\n),\nnet AS (\n  SELECT \n    d.[HAUS],\n    d.[ANLAGE],\n    d.[ME_MA_ID],\n    d.[EQUNR],\n    d.[HOUSE_NUM1],\n    d.[ENTSCHEIDUNG],\n    n.TITLE,\n    n.FORENAME,\n    n.SURNAME,\n    n.STREET,\n    n.STREETNO,\n    n.POST_CODE1,\n    n.CITY1,\n    n.CITY2,\n    n.EMAIL,\n    eablg.[Meter Reading (MR) Doc. No.]\n  FROM J09A_temp d\n  LEFT JOIN eabl eab ON d.EQUNR = eab.EQUNR\n  LEFT JOIN eablg ON eab.[Meter Reading (MR) Doc. No.] = eablg.[Meter Reading (MR) Doc. No.]\n  LEFT JOIN net_master n ON d.EQUNR = n.EQUNR\n)\nSELECT\n  COALESCE(sales.[Meter Reading (MR) Doc. No.], net.[Meter Reading (MR) Doc. No.]) AS \"Meter Reading (MR) Doc. No.\",\n  COALESCE(sales.HAUS, net.HAUS) AS HAUS,\n  COALESCE(sales.ANLAGE, net.ANLAGE) AS ANLAGE,\n  COALESCE(sales.ME_MA_ID, net.ME_MA_ID) AS ME_MA_ID,\n  COALESCE(sales.EQUNR, net.EQUNR) AS EQUNR,\n  COALESCE(sales.HOUSE_NUM1, net.HOUSE_NUM1) AS HOUSE_NUM1,\n  COALESCE(sales.ENTSCHEIDUNG, net.ENTSCHEIDUNG) AS ENTSCHEIDUNG,\n  CASE WHEN sales.EQUNR IS NOT NULL THEN sales.TITLE ELSE net.TITLE END AS TITLE,\n  CASE WHEN sales.EQUNR IS NOT NULL THEN sales.FORENAME ELSE net.FORENAME END AS FORENAME,\n  CASE WHEN sales.EQUNR IS NOT NULL THEN sales.SURNAME ELSE net.SURNAME END AS SURNAME,\n  CASE WHEN sales.EQUNR IS NOT NULL THEN sales.STREET ELSE net.STREET END AS STREET,\n  CASE WHEN sales.EQUNR IS NOT NULL THEN sales.STREETNO ELSE net.STREETNO END AS STREETNO,\n  CASE WHEN sales.EQUNR IS NOT NULL THEN sales.POST_CODE1 ELSE net.POST_CODE1 END AS POST_CODE1,\n  CASE WHEN sales.EQUNR IS NOT NULL THEN sales.CITY1 ELSE net.CITY1 END AS CITY1,\n  CASE WHEN sales.EQUNR IS NOT NULL THEN sales.CITY2 ELSE net.CITY2 END AS CITY2,\n  CASE WHEN sales.EQUNR IS NOT NULL THEN sales.EMAIL ELSE net.EMAIL END AS EMAIL\nFROM sales\nFULL OUTER JOIN net\n  ON sales.EQUNR = net.EQUNR\n  AND sales.HAUS = net.HAUS\n  AND sales.ANLAGE = net.ANLAGE\n  AND sales.ME_MA_ID = net.ME_MA_ID;",
