              "sql_query": "WITH base AS (\n  SELECT \n    t.HAUS,\n    t.ANLAGE,\n    t.ME_MA_ID,\n    t.EQUNR,\n    t.HOUSE_NUM1,\n    t.ENTSCHEIDUNG,\n    eablg.\"Meter Reading (MR) Doc. No.\",\n    COALESCE(sales.EQUNR, net.EQUNR) AS contact_EQUNR,\n    CASE WHEN sales.EQUNR IS NOT NULL THEN sales.TITLE ELSE net.TITLE END AS TITLE,\n    CASE WHEN sales.EQUNR IS NOT NULL THEN sales.FORENAME ELSE net.FORENAME END AS FORENAME,\n    CASE WHEN sales.EQUNR IS NOT NULL THEN sales.SURNAME ELSE net.SURNAME END AS SURNAME,\n    CASE WHEN sales.EQUNR IS NOT NULL THEN sales.STREET ELSE net.STREET END AS STREET,\n    CASE WHEN sales.EQUNR IS NOT NULL THEN sales.STREETNO ELSE net.STREETNO END AS STREETNO,\n    CASE WHEN sales.EQUNR IS NOT NULL THEN sales.POST_CODE1 ELSE net.POST_CODE1 END AS POST_CODE1,\n    CASE WHEN sales.EQUNR IS NOT NULL THEN sales.CITY1 ELSE net.CITY1 END AS CITY1,\n    CASE WHEN sales.EQUNR IS NOT NULL THEN sales.CITY2 ELSE net.CITY2 END AS CITY2,\n    CASE WHEN sales.EQUNR IS NOT NULL THEN sales.EMAIL ELSE net.EMAIL END AS EMAIL\n  FROM J09C_temp t\n  LEFT JOIN eablg ON eablg.Installation = t.ANLAGE\n  LEFT JOIN net_master net ON net.EQUNR = t.EQUNR\n  LEFT JOIN sales_master sales ON sales.EQUNR = t.EQUNR\n)\nSELECT \n  \"Meter Reading (MR) Doc. No.\",\n  HAUS,\n  ANLAGE AS ANLAGE,\n  ME_MA_ID AS ME_MA_ID,\n  EQUNR,\n  HOUSE_NUM1,\n  ENTSCHEIDUNG,\n  TITLE,\n  FORENAME,\n  SURNAME,\n  STREET,\n  STREETNO,\n  POST_CODE1,\n  CITY1,\n  CITY2,\n  EMAIL\nFROM base;",
