              "sqlite_command": "CREATE TABLE J09D_joined AS\nSELECT\n  eablg.\"Meter Reading (MR) Doc. No.\",\n  jt.HAUS,\n  jt.ANLAGE,\n  jt.ME_MA_ID,\n  jt.EQUNR,\n  jt.HOUSE_NUM1,\n  jt.ENTSCHEIDUNG,\n  COALESCE(sales.TITLE, net.TITLE) AS TITLE,\n  COALESCE(sales.FORENAME, net.FORENAME) AS FORENAME,\n  COALESCE(sales.SURNAME, net.SURNAME) AS SURNAME,\n  COALESCE(sales.STREET, net.STREET) AS STREET,\n  COALESCE(sales.STREETNO, net.STREETNO) AS STREETNO,\n  COALESCE(sales.POST_CODE1, net.POST_CODE1) AS POST_CODE1,\n  COALESCE(sales.CITY1, net.CITY1) AS CITY1,\n  COALESCE(sales.CITY2, net.CITY2) AS CITY2,\n  COALESCE(sales.EMAIL, net.EMAIL) AS EMAIL\nFROM J09D_temp jt\nLEFT JOIN eablg ON eablg.Installation = jt.ANLAGE\nLEFT JOIN net_master net ON net.EQUNR = jt.EQUNR\nLEFT JOIN sales_master sales ON sales.EQUNR = jt.EQUNR;"
