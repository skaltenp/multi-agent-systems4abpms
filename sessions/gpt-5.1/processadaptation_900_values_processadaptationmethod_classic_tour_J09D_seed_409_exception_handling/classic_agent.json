              "sql_query": "WITH base AS (\n  SELECT \n    t.\"HAUS\",\n    t.\"ANLAGE\",\n    t.\"ME_MA_ID\",\n    t.\"EQUNR\",\n    t.\"HOUSE_NUM1\",\n    t.\"ENTSCHEIDUNG\",\n    eablg.\"Meter Reading (MR) Doc. No.\",\n    COALESCE(s.\"TITLE\", n.\"TITLE\") AS TITLE,\n    COALESCE(s.\"FORENAME\", n.\"FORENAME\") AS FORENAME,\n    COALESCE(s.\"SURNAME\", n.\"SURNAME\") AS SURNAME,\n    COALESCE(s.\"STREET\", n.\"STREET\") AS STREET,\n    COALESCE(s.\"STREETNO\", n.\"STREETNO\") AS STREETNO,\n    COALESCE(s.\"POST_CODE1\", n.\"POST_CODE1\") AS POST_CODE1,\n    COALESCE(s.\"CITY1\", n.\"CITY1\") AS CITY1,\n    COALESCE(s.\"CITY2\", n.\"CITY2\") AS CITY2,\n    COALESCE(s.\"EMAIL\", n.\"EMAIL\") AS EMAIL\n  FROM J09D_temp t\n  LEFT JOIN eablg ON eablg.\"Installation\" = t.\"ANLAGE\"\n  LEFT JOIN sales_master s ON s.\"EQUNR\" = t.\"EQUNR\"\n  LEFT JOIN net_master n ON n.\"EQUNR\" = t.\"EQUNR\" AND s.\"EQUNR\" IS NULL\n)\nSELECT \n  \"Meter Reading (MR) Doc. No.\",\n  HAUS,\n  ANLAGE AS \"ANLAGE\",\n  ME_MA_ID,\n  EQUNR,\n  HOUSE_NUM1,\n  ENTSCHEIDUNG,\n  TITLE,\n  FORENAME,\n  SURNAME,\n  STREET,\n  STREETNO,\n  POST_CODE1,\n  CITY1,\n  CITY2,\n  EMAIL\nFROM base;",
              "filename": "J09D"
            },
