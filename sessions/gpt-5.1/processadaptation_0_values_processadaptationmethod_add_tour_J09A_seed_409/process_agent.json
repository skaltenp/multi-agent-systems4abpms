            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TABLE J09A_enriched AS\nWITH net AS (\n    SELECT n.*\n    FROM net_master n\n),\n\nsales AS (\n    SELECT s.*\n    FROM sales_master s\n)\n\nSELECT \n    j.\"Meter Reading (MR) Doc. No.\",\n    j.HAUS,\n    j.ANLAGE,\n    j.ME_MA_ID,\n    j.EQUNR,\n    j.HOUSE_NUM1,\n    j.ENTSCHEIDUNG,\n    COALESCE(s.TITLE, CASE WHEN s.EQUNR IS NOT NULL THEN s.TITLE ELSE n.TITLE END) AS TITLE,\n    COALESCE(s.FORENAME, CASE WHEN s.EQUNR IS NOT NULL THEN s.FORENAME ELSE n.FORENAME END) AS FORENAME,\n    COALESCE(s.SURNAME, CASE WHEN s.EQUNR IS NOT NULL THEN s.SURNAME ELSE n.SURNAME END) AS SURNAME,\n    COALESCE(s.STREET, CASE WHEN s.EQUNR IS NOT NULL THEN s.STREET ELSE n.STREET END) AS STREET,\n    COALESCE(s.STREETNO, CASE WHEN s.EQUNR IS NOT NULL THEN s.STREETNO ELSE n.STREETNO END) AS STREETNO,\n    COALESCE(s.POST_CODE1, CASE WHEN s.EQUNR IS NOT NULL THEN s.POST_CODE1 ELSE n.POST_CODE1 END) AS POST_CODE1,\n    COALESCE(s.CITY1, CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY1 ELSE n.CITY1 END) AS CITY1,\n    COALESCE(s.CITY2, CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY2 ELSE n.CITY2 END) AS CITY2,\n    COALESCE(s.EMAIL, CASE WHEN s.EQUNR IS NOT NULL THEN s.EMAIL ELSE n.EMAIL END) AS EMAIL\nFROM J09A_joined j\nLEFT JOIN net n ON j.EQUNR = n.EQUNR\nLEFT JOIN sales s ON j.EQUNR = s.EQUNR;"
            },
