              "sql_query": "WITH eablg_join AS (\n  SELECT \n    j.HAUS,\n    j.ANLAGE,\n    j.ME_MA_ID,\n    j.EQUNR,\n    j.HOUSE_NUM1,\n    j.ENTSCHEIDUNG,\n    e.\"Meter Reading (MR) Doc. No.\",\n    ROW_NUMBER() OVER (PARTITION BY j.ANLAGE ORDER BY e.\"Meter Reading (MR) Doc. No.\") AS rn\n  FROM J09C_temp j\n  LEFT JOIN eablg e\n    ON j.ANLAGE = e.Installation\n),\njoined AS (\n  SELECT \n    eab.\"Meter Reading (MR) Doc. No.\",\n    eab.HAUS,\n    eab.ANLAGE,\n    eab.ME_MA_ID,\n    eab.EQUNR,\n    eab.HOUSE_NUM1,\n    eab.ENTSCHEIDUNG,\n    COALESCE(sm.TITLE, nm.TITLE) AS TITLE,\n    COALESCE(sm.FORENAME, nm.FORENAME) AS FORENAME,\n    COALESCE(sm.SURNAME, nm.SURNAME) AS SURNAME,\n    COALESCE(sm.STREET, nm.STREET) AS STREET,\n    COALESCE(sm.STREETNO, nm.STREETNO) AS STREETNO,\n    COALESCE(sm.POST_CODE1, nm.POST_CODE1) AS POST_CODE1,\n    COALESCE(sm.CITY1, nm.CITY1) AS CITY1,\n    COALESCE(sm.CITY2, nm.CITY2) AS CITY2,\n    COALESCE(sm.EMAIL, nm.EMAIL) AS EMAIL,\n    sm.TITLE AS SALES_TITLE\n  FROM eablg_join eab\n  LEFT JOIN net_master nm\n    ON eab.EQUNR = nm.EQUNR\n  LEFT JOIN sales_master sm\n    ON eab.EQUNR = sm.EQUNR\n  WHERE eab.rn = 1\n)\nSELECT\n  \"Meter Reading (MR) Doc. No.\",\n  HAUS,\n  ANLAGE,\n  ME_MA_ID,\n  EQUNR,\n  HOUSE_NUM1,\n  ENTSCHEIDUNG,\n  CASE WHEN SALES_TITLE IS NOT NULL THEN TITLE ELSE NULL END AS TITLE,\n  CASE WHEN SALES_TITLE IS NOT NULL THEN FORENAME ELSE NULL END AS FORENAME,\n  CASE WHEN SALES_TITLE IS NOT NULL THEN SURNAME ELSE NULL END AS SURNAME,\n  CASE WHEN SALES_TITLE IS NOT NULL THEN STREET ELSE NULL END AS STREET,\n  CASE WHEN SALES_TITLE IS NOT NULL THEN STREETNO ELSE NULL END AS STREETNO,\n  CASE WHEN SALES_TITLE IS NOT NULL THEN POST_CODE1 ELSE NULL END AS POST_CODE1,\n  CASE WHEN SALES_TITLE IS NOT NULL THEN CITY1 ELSE NULL END AS CITY1,\n  CASE WHEN SALES_TITLE IS NOT NULL THEN CITY2 ELSE NULL END AS CITY2,\n  CASE WHEN SALES_TITLE IS NOT NULL THEN EMAIL ELSE NULL END AS EMAIL\nFROM joined;",
