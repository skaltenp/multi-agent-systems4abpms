          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TABLE J09A_enriched AS\nWITH base AS (\n  SELECT \n    t.HAUS,\n    t.ANLAGE,\n    t.ME_MA_ID,\n    t.EQUNR,\n    t.HOUSE_NUM1,\n    t.ENTSCHEIDUNG,\n    e.\"Meter Reading (MR) Doc. No.\",\n    e.Installation\n  FROM J09A_temp t\n  LEFT JOIN eablg e\n    ON e.Installation = t.ANLAGE\n),\nnet AS (\n  SELECT \n    EQUNR,\n    TITLE AS net_TITLE,\n    FORENAME AS net_FORENAME,\n    SURNAME AS net_SURNAME,\n    STREET AS net_STREET,\n    STREETNO AS net_STREETNO,\n    POST_CODE1 AS net_POST_CODE1,\n    CITY1 AS net_CITY1,\n    CITY2 AS net_CITY2,\n    EMAIL AS net_EMAIL\n  FROM net_master\n),\nsales AS (\n  SELECT \n    EQUNR,\n    TITLE AS sales_TITLE,\n    FORENAME AS sales_FORENAME,\n    SURNAME AS sales_SURNAME,\n    STREET AS sales_STREET,\n    STREETNO AS sales_STREETNO,\n    POST_CODE1 AS sales_POST_CODE1,\n    CITY1 AS sales_CITY1,\n    CITY2 AS sales_CITY2,\n    EMAIL AS sales_EMAIL\n  FROM sales_master\n)\nSELECT\n  b.\"Meter Reading (MR) Doc. No.\",\n  b.HAUS,\n  b.ANLAGE,\n  b.ME_MA_ID,\n  b.EQUNR,\n  b.HOUSE_NUM1,\n  b.ENTSCHEIDUNG,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_TITLE ELSE n.net_TITLE END AS TITLE,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_FORENAME ELSE n.net_FORENAME END AS FORENAME,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_SURNAME ELSE n.net_SURNAME END AS SURNAME,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_STREET ELSE n.net_STREET END AS STREET,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_STREETNO ELSE n.net_STREETNO END AS STREETNO,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_POST_CODE1 ELSE n.net_POST_CODE1 END AS POST_CODE1,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_CITY1 ELSE n.net_CITY1 END AS CITY1,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_CITY2 ELSE n.net_CITY2 END AS CITY2,\n  CASE WHEN s.EQUNR IS NOT NULL THEN s.sales_EMAIL ELSE n.net_EMAIL END AS EMAIL\nFROM base b\nLEFT JOIN net n\n  ON n.EQUNR = b.EQUNR\nLEFT JOIN sales s\n  ON s.EQUNR = b.EQUNR;"
            },
