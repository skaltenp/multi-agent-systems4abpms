              "sqlite_command": "CREATE TABLE IF NOT EXISTS J09B_joined AS\nSELECT d.\"Meter Reading (MR) Doc. No.\", d.HAUS, d.ANLAGE, d.ME_MA_ID, d.EQUNR, d.HOUSE_NUM1, d.ENTSCHEIDUNG,\n       COALESCE(s.TITLE, n.TITLE) AS TITLE,\n       COALESCE(s.FORENAME, n.FORENAME) AS FORENAME,\n       COALESCE(s.SURNAME, n.SURNAME) AS SURNAME,\n       COALESCE(s.STREET, n.STREET) AS STREET,\n       COALESCE(s.STREETNO, n.STREETNO) AS STREETNO,\n       COALESCE(s.POST_CODE1, n.POST_CODE1) AS POST_CODE1,\n       COALESCE(s.CITY1, n.CITY1) AS CITY1,\n       COALESCE(s.CITY2, n.CITY2) AS CITY2,\n       COALESCE(s.EMAIL, n.EMAIL) AS EMAIL\nFROM (\n    SELECT dt.*, eabl.\"Meter Reading (MR) Doc. No.\" \n    FROM J09B_temp dt\n    LEFT JOIN eabl ON dt.EQUNR = eabl.EQUNR\n) d\nLEFT JOIN eablg ON d.\"Meter Reading (MR) Doc. No.\" = eablg.\"Meter Reading (MR) Doc. No.\"\nLEFT JOIN net_master n ON d.EQUNR = n.EQUNR\nLEFT JOIN sales_master s ON d.EQUNR = s.EQUNR;"
