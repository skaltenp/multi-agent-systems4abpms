            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "CREATE TABLE J09D_enriched AS\nWITH base AS (\n    SELECT \n        j.*, \n        eablg.\"Meter Reading (MR) Doc. No.\" AS MR_Doc_No,\n        eablg.Installation,\n        sm.TITLE AS s_TITLE, sm.FORENAME AS s_FORENAME, sm.SURNAME AS s_SURNAME,\n        sm.STREET AS s_STREET, sm.STREETNO AS s_STREETNO, sm.POST_CODE1 AS s_POST_CODE1,\n        sm.CITY1 AS s_CITY1, sm.CITY2 AS s_CITY2, sm.EMAIL AS s_EMAIL,\n        nm.TITLE AS n_TITLE, nm.FORENAME AS n_FORENAME, nm.SURNAME AS n_SURNAME,\n        nm.STREET AS n_STREET, nm.STREETNO AS n_STREETNO, nm.POST_CODE1 AS n_POST_CODE1,\n        nm.CITY1 AS n_CITY1, nm.CITY2 AS n_CITY2, nm.EMAIL AS n_EMAIL\n    FROM J09D_temp j\n    LEFT JOIN eablg ON eablg.Installation = j.ANLAGE\n    LEFT JOIN sales_master sm ON sm.EQUNR = j.EQUNR\n    LEFT JOIN net_master nm ON nm.EQUNR = j.EQUNR\n)\nSELECT \n    MR_Doc_No AS \"Meter Reading (MR) Doc. No.\",\n    HAUS,\n    ANLAGE,\n    ME_MA_ID,\n    EQUNR,\n    HOUSE_NUM1,\n    ENTSCHEIDUNG,\n    CASE WHEN s_TITLE IS NOT NULL THEN s_TITLE ELSE n_TITLE END AS TITLE,\n    CASE WHEN s_FORENAME IS NOT NULL THEN s_FORENAME ELSE n_FORENAME END AS FORENAME,\n    CASE WHEN s_SURNAME IS NOT NULL THEN s_SURNAME ELSE n_SURNAME END AS SURNAME,\n    CASE WHEN s_STREET IS NOT NULL THEN s_STREET ELSE n_STREET END AS STREET,\n    CASE WHEN s_STREETNO IS NOT NULL THEN s_STREETNO ELSE n_STREETNO END AS STREETNO,\n    CASE WHEN s_POST_CODE1 IS NOT NULL THEN s_POST_CODE1 ELSE n_POST_CODE1 END AS POST_CODE1,\n    CASE WHEN s_CITY1 IS NOT NULL THEN s_CITY1 ELSE n_CITY1 END AS CITY1,\n    CASE WHEN s_CITY2 IS NOT NULL THEN s_CITY2 ELSE n_CITY2 END AS CITY2,\n    CASE WHEN s_EMAIL IS NOT NULL THEN s_EMAIL ELSE n_EMAIL END AS EMAIL\nFROM base;"
            },
