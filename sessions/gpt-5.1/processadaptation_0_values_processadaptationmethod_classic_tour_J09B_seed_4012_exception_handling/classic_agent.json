              "sqlite_command": "UPDATE J09B_temp\nSET ENTSCHEIDUNG = CASE\n    WHEN HOUSE_NUM1 = 0 THEN 'EVU'\n    WHEN HAUS IN (\n        SELECT HAUS\n        FROM J09B_temp\n        GROUP BY HAUS\n        HAVING COUNT(DISTINCT EQUNR) < 3\n    ) THEN 'KSA'\n    ELSE 'EVU'\nEND;"
