        "tool_calls": [
          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH enriched AS (\n  SELECT \n    t.HAUS,\n    t.ANLAGE,\n    t.ME_MA_ID,\n    t.EQUNR,\n    t.HOUSE_NUM1,\n    t.ENTSCHEIDUNG,\n    eablg.\"Meter Reading (MR) Doc. No.\",\n    -- Prefer sales_master data when available\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.TITLE ELSE NULL END AS TITLE,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.FORENAME ELSE NULL END AS FORENAME,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.SURNAME ELSE NULL END AS SURNAME,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.STREET ELSE NULL END AS STREET,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.STREETNO ELSE NULL END AS STREETNO,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.POST_CODE1 ELSE NULL END AS POST_CODE1,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY1 ELSE NULL END AS CITY1,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.CITY2 ELSE NULL END AS CITY2,\n    CASE WHEN s.EQUNR IS NOT NULL THEN s.EMAIL ELSE NULL END AS EMAIL,\n    -- Net master data only when sales is missing\n    CASE WHEN s.EQUNR IS NULL THEN n.TITLE ELSE NULL END AS TITLE_net,\n    CASE WHEN s.EQUNR IS NULL THEN n.FORENAME ELSE NULL END AS FORENAME_net,\n    CASE WHEN s.EQUNR IS NULL THEN n.SURNAME ELSE NULL END AS SURNAME_net,\n    CASE WHEN s.EQUNR IS NULL THEN n.STREET ELSE NULL END AS STREET_net,\n    CASE WHEN s.EQUNR IS NULL THEN n.STREETNO ELSE NULL END AS STREETNO_net,\n    CASE WHEN s.EQUNR IS NULL THEN n.POST_CODE1 ELSE NULL END AS POST_CODE1_net,\n    CASE WHEN s.EQUNR IS NULL THEN n.CITY1 ELSE NULL END AS CITY1_net,\n    CASE WHEN s.EQUNR IS NULL THEN n.CITY2 ELSE NULL END AS CITY2_net,\n    CASE WHEN s.EQUNR IS NULL THEN n.EMAIL ELSE NULL END AS EMAIL_net\n  FROM J09D_temp t\n  LEFT JOIN eablg ON eablg.Installation = t.ANLAGE\n  LEFT JOIN sales_master s ON s.EQUNR = t.EQUNR\n  LEFT JOIN net_master n ON n.EQUNR = t.EQUNR\n)\nSELECT\n  \"Meter Reading (MR) Doc. No.\",\n  HAUS,\n  ANLAGE,\n  ME_MA_ID,\n  EQUNR,\n  HOUSE_NUM1,\n  ENTSCHEIDUNG,\n  COALESCE(TITLE, TITLE_net) AS TITLE,\n  COALESCE(FORENAME, FORENAME_net) AS FORENAME,\n  COALESCE(SURNAME, SURNAME_net) AS SURNAME,\n  COALESCE(STREET, STREET_net) AS STREET,\n  COALESCE(STREETNO, STREETNO_net) AS STREETNO,\n  COALESCE(POST_CODE1, POST_CODE1_net) AS POST_CODE1,\n  COALESCE(CITY1, CITY1_net) AS CITY1,\n  COALESCE(CITY2, CITY2_net) AS CITY2,\n  COALESCE(EMAIL, EMAIL_net) AS EMAIL\nFROM enriched;",
              "filename": "J09D"
            },
