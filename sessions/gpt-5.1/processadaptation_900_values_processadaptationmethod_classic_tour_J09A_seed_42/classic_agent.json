        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "WITH eq_counts AS (\n  SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n  FROM J09A_temp\n  GROUP BY HAUS\n), base_decisions AS (\n  SELECT t.rowid AS rid,\n         t.HAUS,\n         t.HOUSE_NUM1,\n         c.eq_count,\n         CASE\n           WHEN t.HOUSE_NUM1 = 0 THEN 'EVU'\n           WHEN t.HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n           WHEN t.HOUSE_NUM1 BETWEEN 900 AND 999 THEN 'EVU'\n           WHEN c.eq_count < 3 THEN 'KSA'\n           ELSE 'EVU'\n         END AS decision\n  FROM J09A_temp t\n  LEFT JOIN eq_counts c ON t.HAUS = c.HAUS\n)\nUPDATE J09A_temp\nSET ENTSCHEIDUNG = (\n  SELECT decision FROM base_decisions b WHERE b.rid = J09A_temp.rowid\n);"
            },
            "id": "call_9QtADBHWpYE86XbPykRmvl4Q",
            "type": "tool_call"
          }
