              "sql_query": "WITH sales AS (\n  SELECT \n    s.EQUNR,\n    s.TITLE,\n    s.FORENAME,\n    s.SURNAME,\n    s.STREET,\n    s.STREETNO,\n    s.POST_CODE1,\n    s.CITY1,\n    s.CITY2,\n    s.EMAIL\n  FROM sales_master s\n), net_only AS (\n  SELECT \n    n.EQUNR,\n    n.TITLE,\n    n.FORENAME,\n    n.SURNAME,\n    n.STREET,\n    n.STREETNO,\n    n.POST_CODE1,\n    n.CITY1,\n    n.CITY2,\n    n.EMAIL\n  FROM net_master n\n  LEFT JOIN sales_master s ON n.EQUNR = s.EQUNR\n  WHERE s.EQUNR IS NULL\n), contacts AS (\n  SELECT * FROM sales\n  UNION ALL\n  SELECT * FROM net_only\n)\nSELECT \n  eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\",\n  j.HAUS,\n  j.ANLAGE,\n  j.ME_MA_ID,\n  j.EQUNR,\n  j.HOUSE_NUM1,\n  j.ENTSCHEIDUNG,\n  c.TITLE,\n  c.FORENAME,\n  c.SURNAME,\n  c.STREET,\n  c.STREETNO,\n  c.POST_CODE1,\n  c.CITY1,\n  c.CITY2,\n  c.EMAIL\nFROM J09A_temp j\nLEFT JOIN eablg eablg\n  ON eablg.Installation = j.ANLAGE\nLEFT JOIN contacts c\n  ON c.EQUNR = j.EQUNR;",
