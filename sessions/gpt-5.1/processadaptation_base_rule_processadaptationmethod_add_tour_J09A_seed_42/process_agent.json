          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "WITH eq_count AS (\n    SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_total\n    FROM J09A_temp\n    GROUP BY HAUS\n)\nUPDATE J09A_temp\nSET ENTSCHEIDUNG = CASE\n    WHEN eq_total < 3 THEN 'KSA'\n    ELSE 'EVU'\nEND\nFROM eq_count\nWHERE J09A_temp.HAUS = eq_count.HAUS;"
            },
            "id": "call_j55PRmzdv9uxsH00u9EGrN9E",
            "type": "tool_call"
          }
        ],
