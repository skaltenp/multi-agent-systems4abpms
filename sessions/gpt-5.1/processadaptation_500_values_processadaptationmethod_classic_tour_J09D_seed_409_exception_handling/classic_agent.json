        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "WITH eq_counts AS (\n  SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n  FROM J09D_temp\n  GROUP BY HAUS\n), base_decision AS (\n  SELECT \n    t.rowid AS rid,\n    CASE \n      WHEN c.eq_count < 3 THEN 'KSA'\n      ELSE 'EVU'\n    END AS decision\n  FROM J09D_temp t\n  JOIN eq_counts c ON t.HAUS = c.HAUS\n)\nUPDATE J09D_temp\nSET ENTSCHEIDUNG = base_decision.decision\nFROM base_decision\nWHERE J09D_temp.rowid = base_decision.rid;"
            },
            "id": "call_BTT9XqM8EgUx60uAAXMZux3g",
            "type": "tool_call"
          }
