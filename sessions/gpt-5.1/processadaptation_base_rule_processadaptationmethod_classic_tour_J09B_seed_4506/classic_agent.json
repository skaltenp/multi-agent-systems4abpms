              "sqlite_command": "UPDATE J09B_temp\nSET ENTSCHEIDUNG = CASE\n    WHEN HAUS IN (\n        SELECT HAUS FROM (\n            SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count\n            FROM J09B_temp\n            GROUP BY HAUS\n        ) sub\n        WHERE eq_count < 3\n    ) THEN 'KSA'\n    ELSE 'EVU'\nEND;"
