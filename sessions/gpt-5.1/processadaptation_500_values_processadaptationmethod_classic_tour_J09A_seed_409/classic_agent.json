              "sql_query": "SELECT\n  e.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\",\n  j.HAUS,\n  j.ANLAGE,\n  j.ME_MA_ID,\n  j.EQUNR,\n  j.HOUSE_NUM1,\n  j.ENTSCHEIDUNG,\n  COALESCE(s.TITLE, n.TITLE) AS TITLE,\n  COALESCE(s.FORENAME, n.FORENAME) AS FORENAME,\n  COALESCE(s.SURNAME, n.SURNAME) AS SURNAME,\n  COALESCE(s.STREET, n.STREET) AS STREET,\n  COALESCE(s.STREETNO, n.STREETNO) AS STREETNO,\n  COALESCE(s.POST_CODE1, n.POST_CODE1, j.POST_CODE1) AS POST_CODE1,\n  COALESCE(s.CITY1, n.CITY1, j.CITY1) AS CITY1,\n  COALESCE(s.CITY2, n.CITY2, j.CITY2) AS CITY2,\n  COALESCE(s.EMAIL, n.EMAIL) AS EMAIL\nFROM J09A_temp j\nLEFT JOIN eablg e\n  ON j.ANLAGE = e.Installation\nLEFT JOIN sales_master s\n  ON j.EQUNR = s.EQUNR\nLEFT JOIN net_master n\n  ON j.EQUNR = n.EQUNR\n  AND s.EQUNR IS NULL;",
