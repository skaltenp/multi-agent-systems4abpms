              "sql_query": "SELECT e.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\", t.HAUS AS \"HAUS\", t.ANLAGE AS \"ANLAGE\", t.ME_MA_ID AS \"ME_MA_ID\", t.EQUNR AS \"EQUNR\", t.HOUSE_NUM1 AS \"HOUSE_NUM1\", t.ENTSCHEIDUNG AS \"ENTSCHEIDUNG\", COALESCE(NULLIF(s.TITLE,''), n.TITLE) AS \"TITLE\", COALESCE(NULLIF(s.FORENAME,''), n.FORENAME) AS \"FORENAME\", COALESCE(NULLIF(s.SURNAME,''), n.SURNAME) AS \"SURNAME\", COALESCE(NULLIF(s.STREET,''), n.STREET) AS \"STREET\", COALESCE(NULLIF(s.STREETNO,''), n.STREETNO) AS \"STREETNO\", COALESCE(NULLIF(s.POST_CODE1,''), n.POST_CODE1) AS \"POST_CODE1\", COALESCE(NULLIF(s.CITY1,''), n.CITY1) AS \"CITY1\", COALESCE(NULLIF(s.CITY2,''), n.CITY2) AS \"CITY2\", COALESCE(NULLIF(s.EMAIL,''), n.EMAIL) AS \"EMAIL\" FROM J09A_temp t LEFT JOIN eablg e ON e.\"Installation\" = t.ANLAGE LEFT JOIN sales_master s ON s.EQUNR = t.EQUNR LEFT JOIN net_master n ON n.EQUNR = t.EQUNR"
