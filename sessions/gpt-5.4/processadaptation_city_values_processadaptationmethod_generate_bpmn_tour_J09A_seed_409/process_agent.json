              "sqlite_command": "WITH haus_counts AS (SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count FROM J09A_temp GROUP BY HAUS) UPDATE J09A_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 THEN 'EVU' WHEN HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU' WHEN HOUSE_NUM1 BETWEEN 900 AND 999 THEN 'EVU' WHEN CITY2 IN ('Wiblingwerde','Breckerfeld') OR CITY1 IN ('Wiblingwerde','Breckerfeld') THEN 'EVU' WHEN (SELECT eq_count FROM haus_counts hc WHERE hc.HAUS = J09A_temp.HAUS) < 3 THEN 'KSA' ELSE 'EVU' END"
