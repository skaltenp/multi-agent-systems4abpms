          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "SELECT e.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\", t.HAUS AS \"HAUS\", t.ANLAGE AS \"ANLAGE\", t.ME_MA_ID AS \"ME_MA_ID\", t.EQUNR AS \"EQUNR\", t.HOUSE_NUM1 AS \"HOUSE_NUM1\", t.ENTSCHEIDUNG AS \"ENTSCHEIDUNG\", CASE WHEN sm.TITLE IS NOT NULL AND TRIM(sm.TITLE) <> '' THEN sm.TITLE ELSE nm.TITLE END AS \"TITLE\", CASE WHEN sm.FORENAME IS NOT NULL AND TRIM(sm.FORENAME) <> '' THEN sm.FORENAME ELSE nm.FORENAME END AS \"FORENAME\", CASE WHEN sm.SURNAME IS NOT NULL AND TRIM(sm.SURNAME) <> '' THEN sm.SURNAME ELSE nm.SURNAME END AS \"SURNAME\", CASE WHEN sm.STREET IS NOT NULL AND TRIM(sm.STREET) <> '' THEN sm.STREET ELSE nm.STREET END AS \"STREET\", CASE WHEN sm.STREETNO IS NOT NULL AND TRIM(sm.STREETNO) <> '' THEN sm.STREETNO ELSE nm.STREETNO END AS \"STREETNO\", CASE WHEN sm.POST_CODE1 IS NOT NULL THEN sm.POST_CODE1 ELSE nm.POST_CODE1 END AS \"POST_CODE1\", CASE WHEN sm.CITY1 IS NOT NULL AND TRIM(sm.CITY1) <> '' THEN sm.CITY1 ELSE nm.CITY1 END AS \"CITY1\", CASE WHEN sm.CITY2 IS NOT NULL AND TRIM(sm.CITY2) <> '' THEN sm.CITY2 ELSE nm.CITY2 END AS \"CITY2\", CASE WHEN sm.EMAIL IS NOT NULL AND TRIM(sm.EMAIL) <> '' THEN sm.EMAIL ELSE nm.EMAIL END AS \"EMAIL\" FROM J09D_temp t LEFT JOIN eablg g ON t.ANLAGE = g.\"Installation\" LEFT JOIN sales_master sm ON t.EQUNR = sm.EQUNR LEFT JOIN net_master nm ON t.EQUNR = nm.EQUNR LEFT JOIN eabl e ON e.\"Meter Reading (MR) Doc. No.\" = g.\"Meter Reading (MR) Doc. No.\"",
