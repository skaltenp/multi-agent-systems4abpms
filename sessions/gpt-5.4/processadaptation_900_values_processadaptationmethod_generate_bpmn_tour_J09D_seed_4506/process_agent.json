            "name": "prepare_csv",
            "args": {
              "sql_query": "SELECT eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\", t.HAUS AS \"HAUS\", t.ANLAGE AS \"ANLAGE\", t.ME_MA_ID AS \"ME_MA_ID\", t.EQUNR AS \"EQUNR\", t.HOUSE_NUM1 AS \"HOUSE_NUM1\", t.ENTSCHEIDUNG AS \"ENTSCHEIDUNG\", CASE WHEN sm.EQUNR IS NOT NULL AND (COALESCE(sm.TITLE,'') <> '' OR COALESCE(sm.FORENAME,'') <> '' OR COALESCE(sm.SURNAME,'') <> '' OR COALESCE(sm.STREET,'') <> '' OR COALESCE(sm.STREETNO,'') <> '' OR COALESCE(CAST(sm.POST_CODE1 AS TEXT),'') <> '' OR COALESCE(sm.CITY1,'') <> '' OR COALESCE(sm.CITY2,'') <> '' OR COALESCE(sm.EMAIL,'') <> '') THEN sm.TITLE ELSE nm.TITLE END AS \"TITLE\", CASE WHEN sm.EQUNR IS NOT NULL AND (COALESCE(sm.TITLE,'') <> '' OR COALESCE(sm.FORENAME,'') <> '' OR COALESCE(sm.SURNAME,'') <> '' OR COALESCE(sm.STREET,'') <> '' OR COALESCE(sm.STREETNO,'') <> '' OR COALESCE(CAST(sm.POST_CODE1 AS TEXT),'') <> '' OR COALESCE(sm.CITY1,'') <> '' OR COALESCE(sm.CITY2,'') <> '' OR COALESCE(sm.EMAIL,'') <> '') THEN sm.FORENAME ELSE nm.FORENAME END AS \"FORENAME\", CASE WHEN sm.EQUNR IS NOT NULL AND (COALESCE(sm.TITLE,'') <> '' OR COALESCE(sm.FORENAME,'') <> '' OR COALESCE(sm.SURNAME,'') <> '' OR COALESCE(sm.STREET,'') <> '' OR COALESCE(sm.STREETNO,'') <> '' OR COALESCE(CAST(sm.POST_CODE1 AS TEXT),'') <> '' OR COALESCE(sm.CITY1,'') <> '' OR COALESCE(sm.CITY2,'') <> '' OR COALESCE(sm.EMAIL,'') <> '') THEN sm.SURNAME ELSE nm.SURNAME END AS \"SURNAME\", CASE WHEN sm.EQUNR IS NOT NULL AND (COALESCE(sm.TITLE,'') <> '' OR COALESCE(sm.FORENAME,'') <> '' OR COALESCE(sm.SURNAME,'') <> '' OR COALESCE(sm.STREET,'') <> '' OR COALESCE(sm.STREETNO,'') <> '' OR COALESCE(CAST(sm.POST_CODE1 AS TEXT),'') <> '' OR COALESCE(sm.CITY1,'') <> '' OR COALESCE(sm.CITY2,'') <> '' OR COALESCE(sm.EMAIL,'') <> '') THEN sm.STREET ELSE nm.STREET END AS \"STREET\", CASE WHEN sm.EQUNR IS NOT NULL AND (COALESCE(sm.TITLE,'') <> '' OR COALESCE(sm.FORENAME,'') <> '' OR COALESCE(sm.SURNAME,'') <> '' OR COALESCE(sm.STREET,'') <> '' OR COALESCE(sm.STREETNO,'') <> '' OR COALESCE(CAST(sm.POST_CODE1 AS TEXT),'') <> '' OR COALESCE(sm.CITY1,'') <> '' OR COALESCE(sm.CITY2,'') <> '' OR COALESCE(sm.EMAIL,'') <> '') THEN sm.STREETNO ELSE nm.STREETNO END AS \"STREETNO\", CASE WHEN sm.EQUNR IS NOT NULL AND (COALESCE(sm.TITLE,'') <> '' OR COALESCE(sm.FORENAME,'') <> '' OR COALESCE(sm.SURNAME,'') <> '' OR COALESCE(sm.STREET,'') <> '' OR COALESCE(sm.STREETNO,'') <> '' OR COALESCE(CAST(sm.POST_CODE1 AS TEXT),'') <> '' OR COALESCE(sm.CITY1,'') <> '' OR COALESCE(sm.CITY2,'') <> '' OR COALESCE(sm.EMAIL,'') <> '') THEN sm.POST_CODE1 ELSE nm.POST_CODE1 END AS \"POST_CODE1\", CASE WHEN sm.EQUNR IS NOT NULL AND (COALESCE(sm.TITLE,'') <> '' OR COALESCE(sm.FORENAME,'') <> '' OR COALESCE(sm.SURNAME,'') <> '' OR COALESCE(sm.STREET,'') <> '' OR COALESCE(sm.STREETNO,'') <> '' OR COALESCE(CAST(sm.POST_CODE1 AS TEXT),'') <> '' OR COALESCE(sm.CITY1,'') <> '' OR COALESCE(sm.CITY2,'') <> '' OR COALESCE(sm.EMAIL,'') <> '') THEN sm.CITY1 ELSE nm.CITY1 END AS \"CITY1\", CASE WHEN sm.EQUNR IS NOT NULL AND (COALESCE(sm.TITLE,'') <> '' OR COALESCE(sm.FORENAME,'') <> '' OR COALESCE(sm.SURNAME,'') <> '' OR COALESCE(sm.STREET,'') <> '' OR COALESCE(sm.STREETNO,'') <> '' OR COALESCE(CAST(sm.POST_CODE1 AS TEXT),'') <> '' OR COALESCE(sm.CITY1,'') <> '' OR COALESCE(sm.CITY2,'') <> '' OR COALESCE(sm.EMAIL,'') <> '') THEN sm.CITY2 ELSE nm.CITY2 END AS \"CITY2\", CASE WHEN sm.EQUNR IS NOT NULL AND (COALESCE(sm.TITLE,'') <> '' OR COALESCE(sm.FORENAME,'') <> '' OR COALESCE(sm.SURNAME,'') <> '' OR COALESCE(sm.STREET,'') <> '' OR COALESCE(sm.STREETNO,'') <> '' OR COALESCE(CAST(sm.POST_CODE1 AS TEXT),'') <> '' OR COALESCE(sm.CITY1,'') <> '' OR COALESCE(sm.CITY2,'') <> '' OR COALESCE(sm.EMAIL,'') <> '') THEN sm.EMAIL ELSE nm.EMAIL END AS \"EMAIL\" FROM J09D_temp t LEFT JOIN eablg ON eablg.\"Installation\" = t.ANLAGE LEFT JOIN sales_master sm ON sm.EQUNR = t.EQUNR LEFT JOIN net_master nm ON nm.EQUNR = t.EQUNR",
