            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "DROP TABLE IF EXISTS J09B_temp; CREATE TABLE J09B_temp AS SELECT * FROM decision_talbe WHERE TOUR LIKE 'J09B%'; ALTER TABLE J09B_temp ADD COLUMN ENTSCHEIDUNG TEXT; UPDATE J09B_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 THEN 'EVU' WHEN (SELECT COUNT(DISTINCT t2.EQUNR) FROM J09B_temp t2 WHERE t2.HAUS = J09B_temp.HAUS) < 3 THEN 'KSA' ELSE 'EVU' END;"
