              "sql_query": "SELECT eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\", j.HAUS AS \"HAUS\", j.ANLAGE AS \"ANLAGE\", j.ME_MA_ID AS \"ME_MA_ID\", j.EQUNR AS \"EQUNR\", j.HOUSE_NUM1 AS \"HOUSE_NUM1\", j.ENTSCHEIDUNG AS \"ENTSCHEIDUNG\", COALESCE(NULLIF(sm.TITLE,''), nm.TITLE) AS \"TITLE\", COALESCE(NULLIF(sm.FORENAME,''), nm.FORENAME) AS \"FORENAME\", COALESCE(NULLIF(sm.SURNAME,''), nm.SURNAME) AS \"SURNAME\", COALESCE(NULLIF(sm.STREET,''), nm.STREET) AS \"STREET\", COALESCE(NULLIF(sm.STREETNO,''), nm.STREETNO) AS \"STREETNO\", COALESCE(NULLIF(sm.POST_CODE1,''), nm.POST_CODE1) AS \"POST_CODE1\", COALESCE(NULLIF(sm.CITY1,''), nm.CITY1) AS \"CITY1\", COALESCE(NULLIF(sm.CITY2,''), nm.CITY2) AS \"CITY2\", COALESCE(NULLIF(sm.EMAIL,''), nm.EMAIL) AS \"EMAIL\" FROM J09C_temp j LEFT JOIN EABLG eablg ON j.ANLAGE = eablg.Installation LEFT JOIN SALES_MASTER sm ON j.EQUNR = sm.EQUNR LEFT JOIN NET_MASTER nm ON j.EQUNR = nm.EQUNR"
