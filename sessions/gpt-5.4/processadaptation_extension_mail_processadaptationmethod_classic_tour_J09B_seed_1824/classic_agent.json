        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "UPDATE J09B_temp\nSET ENTSCHEIDUNG = CASE\n    WHEN HOUSE_NUM1 = 0 THEN 'EVU'\n    WHEN HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU'\n    WHEN HOUSE_NUM1 BETWEEN 900 AND 999 THEN 'EVU'\n    WHEN UPPER(COALESCE(CITY1,'')) LIKE '%WIBLINGWERDE%' OR UPPER(COALESCE(CITY2,'')) LIKE '%WIBLINGWERDE%'\n      OR UPPER(COALESCE(CITY1,'')) LIKE '%BRECKERFELD%' OR UPPER(COALESCE(CITY2,'')) LIKE '%BRECKERFELD%'\n      THEN 'EVU'\n    WHEN HAUS IN (\n        SELECT HAUS FROM J09B_temp GROUP BY HAUS HAVING COUNT(DISTINCT EQUNR) < 3\n    ) THEN 'KSA'\n    ELSE 'EVU'\nEND;"
            },
            "id": "call_M1bzG30zRH1cBA9LmWElsOKC",
            "type": "tool_call"
          }
        ],
