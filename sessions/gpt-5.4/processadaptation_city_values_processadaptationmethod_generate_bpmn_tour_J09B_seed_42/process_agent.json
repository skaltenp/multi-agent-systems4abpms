            "args": {
              "filename": "J09B",
              "sql_query": "SELECT e.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\", t.HAUS AS \"HAUS\", t.ANLAGE AS \"ANLAGE\", t.ME_MA_ID AS \"ME_MA_ID\", t.EQUNR AS \"EQUNR\", t.HOUSE_NUM1 AS \"HOUSE_NUM1\", t.ENTSCHEIDUNG AS \"ENTSCHEIDUNG\", COALESCE(NULLIF(TRIM(s.TITLE),''), n.TITLE) AS \"TITLE\", COALESCE(NULLIF(TRIM(s.FORENAME),''), n.FORENAME) AS \"FORENAME\", COALESCE(NULLIF(TRIM(s.SURNAME),''), n.SURNAME) AS \"SURNAME\", COALESCE(NULLIF(TRIM(s.STREET),''), n.STREET) AS \"STREET\", COALESCE(NULLIF(TRIM(s.STREETNO),''), n.STREETNO) AS \"STREETNO\", COALESCE(NULLIF(TRIM(CAST(s.POST_CODE1 AS TEXT)),''), CAST(n.POST_CODE1 AS TEXT)) AS \"POST_CODE1\", COALESCE(NULLIF(TRIM(s.CITY1),''), n.CITY1) AS \"CITY1\", COALESCE(NULLIF(TRIM(s.CITY2),''), n.CITY2) AS \"CITY2\", COALESCE(NULLIF(TRIM(s.EMAIL),''), n.EMAIL) AS \"EMAIL\" FROM J09B_temp t LEFT JOIN eablg e ON t.ANLAGE = e.\"Installation\" LEFT JOIN sales_master s ON t.EQUNR = s.EQUNR LEFT JOIN net_master n ON t.EQUNR = n.EQUNR"
