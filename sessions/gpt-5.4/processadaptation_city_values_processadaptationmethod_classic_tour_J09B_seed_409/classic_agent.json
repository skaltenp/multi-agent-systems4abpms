              "sqlite_command": "UPDATE J09B_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 OR HOUSE_NUM1 BETWEEN 500 AND 599 OR HOUSE_NUM1 BETWEEN 900 AND 999 OR UPPER(COALESCE(CITY1, '')) LIKE '%WIBLINGWERDE%' OR UPPER(COALESCE(CITY2, '')) LIKE '%WIBLINGWERDE%' OR UPPER(COALESCE(CITY1, '')) LIKE '%BRECKERFELD%' OR UPPER(COALESCE(CITY2, '')) LIKE '%BRECKERFELD%' THEN 'EVU' WHEN HAUS IN (SELECT HAUS FROM J09B_temp GROUP BY HAUS HAVING COUNT(DISTINCT EQUNR) < 3) THEN 'KSA' ELSE 'EVU' END"
