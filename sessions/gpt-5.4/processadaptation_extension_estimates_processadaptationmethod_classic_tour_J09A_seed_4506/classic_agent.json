          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "DROP TABLE IF EXISTS J09A_temp; CREATE TABLE J09A_temp AS SELECT * FROM decision_table WHERE TOUR LIKE 'J09A%'; ALTER TABLE J09A_temp ADD COLUMN ENTSCHEIDUNG TEXT; UPDATE J09A_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 OR HOUSE_NUM1 BETWEEN 500 AND 599 OR HOUSE_NUM1 BETWEEN 900 AND 999 OR CITY2 IN ('Wiblingwerde','Breckerfeld') OR CITY1 IN ('Wiblingwerde','Breckerfeld') THEN 'EVU' WHEN HAUS IN (SELECT HAUS FROM J09A_temp GROUP BY HAUS HAVING COUNT(DISTINCT EQUNR) < 3) THEN 'KSA' ELSE 'EVU' END; UPDATE J09A_temp SET ENTSCHEIDUNG = 'MANDATORY_READING' WHERE EQUNR IN (SELECT EQUNR FROM eabl WHERE ISTABLART_TXT = 'Maschinelle Schätzung - SAP' AND substr(\"Record created on\",1,4) = '2023' GROUP BY EQUNR HAVING COUNT(*) > 0 INTERSECT SELECT EQUNR FROM eabl WHERE ISTABLART_TXT = 'Maschinelle Schätzung - SAP' AND substr(\"Record created on\",1,4) = '2024' GROUP BY EQUNR HAVING COUNT(*) > 0);"
            },
