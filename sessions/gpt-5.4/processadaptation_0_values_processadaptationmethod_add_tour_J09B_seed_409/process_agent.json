            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "DROP TABLE IF EXISTS J09B_temp;\nCREATE TABLE J09B_temp AS\nSELECT *\nFROM decision_table\nWHERE TOUR LIKE 'J09B%';\nALTER TABLE J09B_temp ADD COLUMN ENTSCHEIDUNG TEXT;\nUPDATE J09B_temp\nSET ENTSCHEIDUNG = (\n  CASE\n    WHEN HOUSE_NUM1 = 0 THEN 'EVU'\n    WHEN (\n      SELECT COUNT(EQUNR)\n      FROM J09B_temp t2\n      WHERE t2.HAUS = J09B_temp.HAUS\n    ) < 3 THEN 'KSA'\n    ELSE 'EVU'\n  END\n);"
