              "sql_query": "SELECT eb.`Meter Reading (MR) Doc. No.` AS `Meter Reading (MR) Doc. No.`, jt.HAUS AS `HAUS`, jt.ANLAGE AS `ANLAGE`, jt.ME_MA_ID AS `ME_MA_ID`, jt.EQUNR AS `EQUNR`, jt.HOUSE_NUM1 AS `HOUSE_NUM1`, jt.ENTSCHEIDUNG AS `ENTSCHEIDUNG`, COALESCE(NULLIF(sm.TITLE, ''), nm.TITLE) AS `TITLE`, COALESCE(NULLIF(sm.FORENAME, ''), nm.FORENAME) AS `FORENAME`, COALESCE(NULLIF(sm.SURNAME, ''), nm.SURNAME) AS `SURNAME`, COALESCE(NULLIF(sm.STREET, ''), nm.STREET) AS `STREET`, COALESCE(NULLIF(sm.STREETNO, ''), nm.STREETNO) AS `STREETNO`, COALESCE(NULLIF(CAST(sm.POST_CODE1 AS TEXT), ''), CAST(nm.POST_CODE1 AS TEXT)) AS `POST_CODE1`, COALESCE(NULLIF(sm.CITY1, ''), nm.CITY1) AS `CITY1`, COALESCE(NULLIF(sm.CITY2, ''), nm.CITY2) AS `CITY2`, COALESCE(NULLIF(sm.EMAIL, ''), nm.EMAIL) AS `EMAIL` FROM J09A_temp jt LEFT JOIN eablg eg ON jt.ANLAGE = eg.Installation LEFT JOIN eabl eb ON eg.`Meter Reading (MR) Doc. No.` = eb.`Meter Reading (MR) Doc. No.` LEFT JOIN sales_master sm ON jt.EQUNR = sm.EQUNR LEFT JOIN net_master nm ON jt.EQUNR = nm.EQUNR",
