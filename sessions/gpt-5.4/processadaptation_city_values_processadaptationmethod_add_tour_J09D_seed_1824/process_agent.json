          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "DROP TABLE IF EXISTS J09D_temp; CREATE TABLE J09D_temp AS SELECT * FROM decision_table WHERE TOUR LIKE 'J09D%'; ALTER TABLE J09D_temp ADD COLUMN ENTSCHEIDUNG TEXT; WITH haus_counts AS (SELECT HAUS, COUNT(EQUNR) AS eq_count FROM J09D_temp GROUP BY HAUS) UPDATE J09D_temp SET ENTSCHEIDUNG = CASE WHEN (SELECT eq_count FROM haus_counts WHERE haus_counts.HAUS = J09D_temp.HAUS) < 3 THEN 'KSA' ELSE 'EVU' END; UPDATE J09D_temp SET ENTSCHEIDUNG = 'EVU' WHERE HOUSE_NUM1 = 0 OR HOUSE_NUM1 BETWEEN 500 AND 599 OR HOUSE_NUM1 BETWEEN 900 AND 999 OR CITY2 IN ('Wiblingwerde','Breckerfeld');"
            },
            "id": "call_QbQ64uqfh1SloDywmd5GqcfY",
