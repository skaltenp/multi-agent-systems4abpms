        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "DROP TABLE IF EXISTS J09C_temp; CREATE TABLE J09C_temp AS SELECT d.*, CAST(NULL AS TEXT) AS ENTSCHEIDUNG, eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\", CASE WHEN sm.EQUNR IS NOT NULL THEN sm.TITLE ELSE nm.TITLE END AS TITLE, CASE WHEN sm.EQUNR IS NOT NULL THEN sm.FORENAME ELSE nm.FORENAME END AS FORENAME, CASE WHEN sm.EQUNR IS NOT NULL THEN sm.SURNAME ELSE nm.SURNAME END AS SURNAME, CASE WHEN sm.EQUNR IS NOT NULL THEN sm.STREET ELSE nm.STREET END AS STREET, CASE WHEN sm.EQUNR IS NOT NULL THEN sm.STREETNO ELSE nm.STREETNO END AS STREETNO, CASE WHEN sm.EQUNR IS NOT NULL THEN sm.POST_CODE1 ELSE nm.POST_CODE1 END AS CONTACT_POST_CODE1, CASE WHEN sm.EQUNR IS NOT NULL THEN sm.CITY1 ELSE nm.CITY1 END AS CONTACT_CITY1, CASE WHEN sm.EQUNR IS NOT NULL THEN sm.CITY2 ELSE nm.CITY2 END AS CONTACT_CITY2, CASE WHEN sm.EQUNR IS NOT NULL THEN sm.EMAIL ELSE nm.EMAIL END AS EMAIL, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.TITLE END AS NET_TITLE, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.FORENAME END AS NET_FORENAME, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.SURNAME END AS NET_SURNAME, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.STREET END AS NET_STREET, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.STREETNO END AS NET_STREETNO, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.POST_CODE1 END AS NET_POST_CODE1, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.CITY1 END AS NET_CITY1, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.CITY2 END AS NET_CITY2, CASE WHEN sm.EQUNR IS NOT NULL THEN NULL ELSE nm.EMAIL END AS NET_EMAIL FROM decision_table d LEFT JOIN eablg ON eablg.Installation = d.ANLAGE LEFT JOIN net_master nm ON nm.EQUNR = d.EQUNR LEFT JOIN sales_master sm ON sm.EQUNR = d.EQUNR WHERE d.TOUR LIKE 'J09C%'; UPDATE J09C_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 OR HOUSE_NUM1 BETWEEN 500 AND 599 OR HOUSE_NUM1 BETWEEN 900 AND 999 OR CITY2 IN ('Wiblingwerde','Breckerfeld') OR CITY1 IN ('Wiblingwerde','Breckerfeld') THEN 'EVU' WHEN HAUS IN (SELECT HAUS FROM J09C_temp GROUP BY HAUS HAVING COUNT(DISTINCT EQUNR) < 3) THEN 'KSA' ELSE 'EVU' END; UPDATE J09C_temp SET ENTSCHEIDUNG = 'MANDATORY_READING' WHERE EQUNR IN (SELECT EQUNR FROM eabl WHERE ISTABLART_TXT = 'Maschinelle Schätzung - SAP' AND substr(\"Record created on\",1,4) = '2023' GROUP BY EQUNR HAVING COUNT(*) > 0 INTERSECT SELECT EQUNR FROM eabl WHERE ISTABLART_TXT = 'Maschinelle Schätzung - SAP' AND substr(\"Record created on\",1,4) = '2024' GROUP BY EQUNR HAVING COUNT(*) > 0); SELECT COUNT(*) AS total_rows, SUM(CASE WHEN ENTSCHEIDUNG='MANDATORY_READING' THEN 1 ELSE 0 END) AS mandatory_rows FROM J09C_temp;"
            },
