          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "DROP TABLE IF EXISTS J09C_temp;\nCREATE TABLE J09C_temp AS\nSELECT *\nFROM decision_table\nWHERE TOUR LIKE 'J09C%';\nALTER TABLE J09C_temp ADD COLUMN ENTSCHEIDUNG TEXT;\n\nUPDATE J09C_temp\nSET ENTSCHEIDUNG = (\n  CASE\n    WHEN (\n      SELECT COUNT(EQUNR)\n      FROM J09C_temp t2\n      WHERE t2.HAUS = J09C_temp.HAUS\n    ) < 3 THEN 'KSA'\n    ELSE 'EVU'\n  END\n);\n\nUPDATE J09C_temp\nSET ENTSCHEIDUNG = 'EVU'\nWHERE HOUSE_NUM1 = 0;"
