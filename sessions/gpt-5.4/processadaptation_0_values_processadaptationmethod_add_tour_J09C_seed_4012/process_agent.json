              "sql_query": "SELECT eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\", t.HAUS, t.ANLAGE, t.ME_MA_ID, t.EQUNR, t.HOUSE_NUM1, t.ENTSCHEIDUNG,\nCASE WHEN sm.EQUNR IS NOT NULL THEN sm.TITLE ELSE nm.TITLE END AS TITLE,\nCASE WHEN sm.EQUNR IS NOT NULL THEN sm.FORENAME ELSE nm.FORENAME END AS FORENAME,\nCASE WHEN sm.EQUNR IS NOT NULL THEN sm.SURNAME ELSE nm.SURNAME END AS SURNAME,\nCASE WHEN sm.EQUNR IS NOT NULL THEN sm.STREET ELSE nm.STREET END AS STREET,\nCASE WHEN sm.EQUNR IS NOT NULL THEN sm.STREETNO ELSE nm.STREETNO END AS STREETNO,\nCASE WHEN sm.EQUNR IS NOT NULL THEN sm.POST_CODE1 ELSE nm.POST_CODE1 END AS POST_CODE1,\nCASE WHEN sm.EQUNR IS NOT NULL THEN sm.CITY1 ELSE nm.CITY1 END AS CITY1,\nCASE WHEN sm.EQUNR IS NOT NULL THEN sm.CITY2 ELSE nm.CITY2 END AS CITY2,\nCASE WHEN sm.EQUNR IS NOT NULL THEN sm.EMAIL ELSE nm.EMAIL END AS EMAIL\nFROM J09C_temp t\nLEFT JOIN eablg ON t.ANLAGE = eablg.Installation\nLEFT JOIN net_master nm ON t.EQUNR = nm.EQUNR\nLEFT JOIN sales_master sm ON t.EQUNR = sm.EQUNR"
