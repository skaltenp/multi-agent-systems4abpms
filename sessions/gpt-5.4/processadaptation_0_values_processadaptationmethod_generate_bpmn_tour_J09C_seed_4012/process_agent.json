              "sql_query": "SELECT eablg.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\",\n       t.HAUS AS \"HAUS\",\n       t.ANLAGE AS \"ANLAGE\",\n       t.ME_MA_ID AS \"ME_MA_ID\",\n       t.EQUNR AS \"EQUNR\",\n       t.HOUSE_NUM1 AS \"HOUSE_NUM1\",\n       t.ENTSCHEIDUNG AS \"ENTSCHEIDUNG\",\n       COALESCE(NULLIF(sm.TITLE, ''), nm.TITLE) AS \"TITLE\",\n       COALESCE(NULLIF(sm.FORENAME, ''), nm.FORENAME) AS \"FORENAME\",\n       COALESCE(NULLIF(sm.SURNAME, ''), nm.SURNAME) AS \"SURNAME\",\n       COALESCE(NULLIF(sm.STREET, ''), nm.STREET) AS \"STREET\",\n       COALESCE(NULLIF(sm.STREETNO, ''), nm.STREETNO) AS \"STREETNO\",\n       COALESCE(NULLIF(sm.POST_CODE1, ''), nm.POST_CODE1) AS \"POST_CODE1\",\n       COALESCE(NULLIF(sm.CITY1, ''), nm.CITY1) AS \"CITY1\",\n       COALESCE(NULLIF(sm.CITY2, ''), nm.CITY2) AS \"CITY2\",\n       COALESCE(NULLIF(sm.EMAIL, ''), nm.EMAIL) AS \"EMAIL\"\nFROM J09C_temp t\nLEFT JOIN eablg ON t.ANLAGE = eablg.\"Installation\"\nLEFT JOIN sales_master sm ON t.EQUNR = sm.EQUNR\nLEFT JOIN net_master nm ON t.EQUNR = nm.EQUNR",
