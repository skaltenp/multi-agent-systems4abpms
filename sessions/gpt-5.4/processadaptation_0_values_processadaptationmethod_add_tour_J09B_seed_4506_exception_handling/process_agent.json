            "args": {
              "sqlite_command": "CREATE TABLE J09B_temp AS\nSELECT \n  d.HAUS,\n  d.ANLAGE,\n  d.ABLEINH,\n  d.TOUR,\n  d.ME_MA_ID,\n  d.CITY1,\n  d.CITY2,\n  d.HOUSE_NUM1,\n  d.POST_CODE1,\n  d.EQUNR,\n  CASE \n    WHEN d.HOUSE_NUM1 = 0 THEN 'EVU'\n    WHEN hc.eq_count < 3 THEN 'KSA'\n    ELSE 'EVU'\n  END AS ENTSCHEIDUNG,\n  e.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\",\n  COALESCE(s.TITLE, n.TITLE) AS TITLE,\n  COALESCE(s.FORENAME, n.FORENAME) AS FORENAME,\n  COALESCE(s.SURNAME, n.SURNAME) AS SURNAME,\n  COALESCE(s.STREET, n.STREET) AS STREET,\n  COALESCE(s.STREETNO, n.STREETNO) AS STREETNO,\n  COALESCE(s.POST_CODE1, n.POST_CODE1) AS POST_CODE1_MASTER,\n  COALESCE(s.CITY1, n.CITY1) AS CITY1_MASTER,\n  COALESCE(s.CITY2, n.CITY2) AS CITY2_MASTER,\n  COALESCE(s.EMAIL, n.EMAIL) AS EMAIL,\n  CASE WHEN s.EQUNR IS NOT NULL THEN n.TITLE ELSE NULL END AS NET_TITLE,\n  CASE WHEN s.EQUNR IS NOT NULL THEN n.FORENAME ELSE NULL END AS NET_FORENAME,\n  CASE WHEN s.EQUNR IS NOT NULL THEN n.SURNAME ELSE NULL END AS NET_SURNAME,\n  CASE WHEN s.EQUNR IS NOT NULL THEN n.STREET ELSE NULL END AS NET_STREET,\n  CASE WHEN s.EQUNR IS NOT NULL THEN n.STREETNO ELSE NULL END AS NET_STREETNO,\n  CASE WHEN s.EQUNR IS NOT NULL THEN n.POST_CODE1 ELSE NULL END AS NET_POST_CODE1,\n  CASE WHEN s.EQUNR IS NOT NULL THEN n.CITY1 ELSE NULL END AS NET_CITY1,\n  CASE WHEN s.EQUNR IS NOT NULL THEN n.CITY2 ELSE NULL END AS NET_CITY2,\n  CASE WHEN s.EQUNR IS NOT NULL THEN n.EMAIL ELSE NULL END AS NET_EMAIL,\n  CASE WHEN s.EQUNR IS NULL THEN s.TITLE ELSE NULL END AS SALES_TITLE,\n  CASE WHEN s.EQUNR IS NULL THEN s.FORENAME ELSE NULL END AS SALES_FORENAME,\n  CASE WHEN s.EQUNR IS NULL THEN s.SURNAME ELSE NULL END AS SALES_SURNAME,\n  CASE WHEN s.EQUNR IS NULL THEN s.STREET ELSE NULL END AS SALES_STREET,\n  CASE WHEN s.EQUNR IS NULL THEN s.STREETNO ELSE NULL END AS SALES_STREETNO,\n  CASE WHEN s.EQUNR IS NULL THEN s.POST_CODE1 ELSE NULL END AS SALES_POST_CODE1,\n  CASE WHEN s.EQUNR IS NULL THEN s.CITY1 ELSE NULL END AS SALES_CITY1,\n  CASE WHEN s.EQUNR IS NULL THEN s.CITY2 ELSE NULL END AS SALES_CITY2,\n  CASE WHEN s.EQUNR IS NULL THEN s.EMAIL ELSE NULL END AS SALES_EMAIL\nFROM decision_table d\nLEFT JOIN (\n  SELECT HAUS, COUNT(EQUNR) AS eq_count\n  FROM decision_table\n  WHERE TOUR LIKE 'J09B%'\n  GROUP BY HAUS\n) hc ON d.HAUS = hc.HAUS\nLEFT JOIN eablg e ON d.ANLAGE = e.Installation\nLEFT JOIN net_master n ON d.EQUNR = n.EQUNR\nLEFT JOIN sales_master s ON d.EQUNR = s.EQUNR\nWHERE d.TOUR LIKE 'J09B%';"
