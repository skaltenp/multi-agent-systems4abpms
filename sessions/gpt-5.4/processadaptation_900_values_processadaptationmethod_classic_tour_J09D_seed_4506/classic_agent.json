            "args": {
              "sqlite_command": "DROP TABLE IF EXISTS J09D_temp; CREATE TABLE J09D_temp AS SELECT * FROM decision_table WHERE TOUR LIKE 'J09D%'; ALTER TABLE J09D_temp ADD COLUMN ENTSCHEIDUNG TEXT; UPDATE J09D_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 OR (HOUSE_NUM1 BETWEEN 500 AND 599) OR (HOUSE_NUM1 BETWEEN 900 AND 999) THEN 'EVU' WHEN HAUS IN (SELECT HAUS FROM J09D_temp GROUP BY HAUS HAVING COUNT(DISTINCT EQUNR) < 3) THEN 'KSA' ELSE 'EVU' END;"
