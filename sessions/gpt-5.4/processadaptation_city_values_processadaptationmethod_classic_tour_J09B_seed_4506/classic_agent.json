          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "WITH haus_counts AS (SELECT HAUS, COUNT(DISTINCT EQUNR) AS eq_count FROM J09B_temp GROUP BY HAUS) UPDATE J09B_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 THEN 'EVU' WHEN HOUSE_NUM1 BETWEEN 500 AND 599 THEN 'EVU' WHEN HOUSE_NUM1 BETWEEN 900 AND 999 THEN 'EVU' WHEN COALESCE(CITY2,'') LIKE '%Wiblingwerde%' OR COALESCE(CITY1,'') LIKE '%Wiblingwerde%' THEN 'EVU' WHEN COALESCE(CITY2,'') LIKE '%Breckerfeld%' OR COALESCE(CITY1,'') LIKE '%Breckerfeld%' THEN 'EVU' WHEN (SELECT eq_count FROM haus_counts hc WHERE hc.HAUS = J09B_temp.HAUS) < 3 THEN 'KSA' ELSE 'EVU' END"
            },
            "id": "call_rc8cFPJTBPHPUhim1KoupKEJ",
            "type": "tool_call"
