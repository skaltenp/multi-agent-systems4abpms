              "sqlite_command": "DROP TABLE IF EXISTS J09D_temp; CREATE TABLE J09D_temp AS SELECT * FROM decision_table WHERE TOUR LIKE 'J09D%'; ALTER TABLE J09D_temp ADD COLUMN ENTSCHEIDUNG TEXT; UPDATE J09D_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 THEN 'EVU' WHEN (SELECT COUNT(DISTINCT t2.EQUNR) FROM J09D_temp t2 WHERE t2.HAUS = J09D_temp.HAUS) < 3 THEN 'KSA' ELSE 'EVU' END;"
