              "sql_query": "SELECT \n  e.\"Meter Reading (MR) Doc. No.\" AS \"Meter Reading (MR) Doc. No.\",\n  t.HAUS AS \"HAUS\",\n  t.ANLAGE AS \"ANLAGE\",\n  t.ME_MA_ID AS \"ME_MA_ID\",\n  t.EQUNR AS \"EQUNR\",\n  t.HOUSE_NUM1 AS \"HOUSE_NUM1\",\n  t.ENTSCHEIDUNG AS \"ENTSCHEIDUNG\",\n  COALESCE(NULLIF(s.TITLE,''), n.TITLE) AS \"TITLE\",\n  COALESCE(NULLIF(s.FORENAME,''), n.FORENAME) AS \"FORENAME\",\n  COALESCE(NULLIF(s.SURNAME,''), n.SURNAME) AS \"SURNAME\",\n  COALESCE(NULLIF(s.STREET,''), n.STREET) AS \"STREET\",\n  COALESCE(NULLIF(s.STREETNO,''), n.STREETNO) AS \"STREETNO\",\n  COALESCE(s.POST_CODE1, n.POST_CODE1) AS \"POST_CODE1\",\n  COALESCE(NULLIF(s.CITY1,''), n.CITY1) AS \"CITY1\",\n  COALESCE(NULLIF(s.CITY2,''), n.CITY2) AS \"CITY2\",\n  COALESCE(NULLIF(s.EMAIL,''), n.EMAIL) AS \"EMAIL\"\nFROM J09C_temp t\nLEFT JOIN eablg e\n  ON t.ANLAGE = e.\"Installation\"\nLEFT JOIN sales_master s\n  ON t.EQUNR = s.EQUNR\nLEFT JOIN net_master n\n  ON t.EQUNR = n.EQUNR"
