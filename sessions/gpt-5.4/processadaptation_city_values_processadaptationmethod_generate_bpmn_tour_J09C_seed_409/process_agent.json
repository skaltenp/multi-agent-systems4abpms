          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "DROP TABLE IF EXISTS J09C_temp;\nCREATE TABLE J09C_temp AS\nSELECT *\nFROM decision_table\nWHERE TOUR LIKE 'J09C%';\n\nALTER TABLE J09C_temp ADD COLUMN ENTSCHEIDUNG TEXT;\n\nUPDATE J09C_temp\nSET ENTSCHEIDUNG = CASE\n    WHEN HAUS IN (\n        SELECT HAUS\n        FROM J09C_temp\n        GROUP BY HAUS\n        HAVING COUNT(DISTINCT EQUNR) < 3\n    ) THEN 'KSA'\n    ELSE 'EVU'\nEND;\n\nUPDATE J09C_temp SET ENTSCHEIDUNG = 'EVU' WHERE HOUSE_NUM1 = 0;\nUPDATE J09C_temp SET ENTSCHEIDUNG = 'EVU' WHERE HOUSE_NUM1 BETWEEN 500 AND 599;\nUPDATE J09C_temp SET ENTSCHEIDUNG = 'EVU' WHERE HOUSE_NUM1 BETWEEN 900 AND 999;\nUPDATE J09C_temp SET ENTSCHEIDUNG = 'EVU' WHERE CITY2 IN ('Wiblingwerde','Breckerfeld');"
            },
            "id": "call_1jtp0OFELTAhz6p8sviehaHO",
