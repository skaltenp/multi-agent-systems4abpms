          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "DROP TABLE IF EXISTS J09C_temp; CREATE TABLE J09C_temp AS SELECT * FROM decision_table WHERE TOUR LIKE 'J09C%'; ALTER TABLE J09C_temp ADD COLUMN ENTSCHEIDUNG TEXT; UPDATE J09C_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 OR HOUSE_NUM1 BETWEEN 500 AND 599 OR HOUSE_NUM1 BETWEEN 900 AND 999 OR CITY2 IN ('Wiblingwerde','Breckerfeld') OR CITY1 IN ('Wiblingwerde','Breckerfeld') THEN 'EVU' WHEN HAUS IN (SELECT HAUS FROM J09C_temp GROUP BY HAUS HAVING COUNT(DISTINCT EQUNR) < 3) THEN 'KSA' ELSE 'EVU' END;"
            },
            "id": "call_Pu0akfLAm7t8YI6IjSqf14WH",
