        "tool_calls": [
          {
            "name": "prepare_csv",
            "args": {
              "sql_query": "WITH base AS (\n  SELECT d.HAUS, d.ANLAGE, d.ME_MA_ID, d.EQUNR, d.HOUSE_NUM1,\n         CASE\n           WHEN d.HOUSE_NUM1 = 0\n             OR d.HOUSE_NUM1 BETWEEN 500 AND 599\n             OR d.HOUSE_NUM1 BETWEEN 900 AND 999\n             OR d.CITY1 IN ('Wiblingwerde','Breckerfeld')\n             OR d.CITY2 IN ('Wiblingwerde','Breckerfeld')\n           THEN 'EVU'\n           WHEN hc.equnr_count < 3 THEN 'KSA'\n           ELSE 'EVU'\n         END AS ENTSCHEIDUNG\n  FROM decision_table d\n  LEFT JOIN (\n    SELECT HAUS, COUNT(DISTINCT EQUNR) AS equnr_count\n    FROM decision_table\n    WHERE TOUR LIKE 'J09C%'\n    GROUP BY HAUS\n  ) hc ON d.HAUS = hc.HAUS\n  WHERE d.TOUR LIKE 'J09C%'\n), enriched AS (\n  SELECT b.*, eg.\"Meter Reading (MR) Doc. No.\" AS mr_doc_no,\n         sm.TITLE AS s_TITLE, sm.FORENAME AS s_FORENAME, sm.SURNAME AS s_SURNAME,\n         sm.STREET AS s_STREET, sm.STREETNO AS s_STREETNO, sm.POST_CODE1 AS s_POST_CODE1,\n         sm.CITY1 AS s_CITY1, sm.CITY2 AS s_CITY2, sm.EMAIL AS s_EMAIL,\n         nm.TITLE AS n_TITLE, nm.FORENAME AS n_FORENAME, nm.SURNAME AS n_SURNAME,\n         nm.STREET AS n_STREET, nm.STREETNO AS n_STREETNO, nm.POST_CODE1 AS n_POST_CODE1,\n         nm.CITY1 AS n_CITY1, nm.CITY2 AS n_CITY2, nm.EMAIL AS n_EMAIL\n  FROM base b\n  LEFT JOIN eablg eg ON eg.Installation = b.ANLAGE\n  LEFT JOIN sales_master sm ON sm.EQUNR = b.EQUNR\n  LEFT JOIN net_master nm ON nm.EQUNR = b.EQUNR AND sm.EQUNR IS NULL\n)\nSELECT mr_doc_no AS \"Meter Reading (MR) Doc. No.\",\n       HAUS,\n       ANLAGE,\n       ME_MA_ID,\n       EQUNR,\n       HOUSE_NUM1,\n       ENTSCHEIDUNG,\n       COALESCE(s_TITLE, n_TITLE) AS TITLE,\n       COALESCE(s_FORENAME, n_FORENAME) AS FORENAME,\n       COALESCE(s_SURNAME, n_SURNAME) AS SURNAME,\n       COALESCE(s_STREET, n_STREET) AS STREET,\n       COALESCE(s_STREETNO, n_STREETNO) AS STREETNO,\n       COALESCE(s_POST_CODE1, n_POST_CODE1) AS POST_CODE1,\n       COALESCE(s_CITY1, n_CITY1) AS CITY1,\n       COALESCE(s_CITY2, n_CITY2) AS CITY2,\n       COALESCE(s_EMAIL, n_EMAIL) AS EMAIL\nFROM enriched",
              "filename": "J09C"
            },
