              "sqlite_command": "DROP TABLE IF EXISTS J09A_temp; CREATE TABLE J09A_temp AS SELECT * FROM decision_table WHERE TOUR LIKE 'J09A%'; ALTER TABLE J09A_temp ADD COLUMN ENTSCHEIDUNG TEXT; UPDATE J09A_temp SET ENTSCHEIDUNG = CASE WHEN HOUSE_NUM1 = 0 THEN 'EVU' WHEN (SELECT COUNT(DISTINCT t2.EQUNR) FROM J09A_temp t2 WHERE t2.HAUS = J09A_temp.HAUS) < 3 THEN 'KSA' ELSE 'EVU' END;"
