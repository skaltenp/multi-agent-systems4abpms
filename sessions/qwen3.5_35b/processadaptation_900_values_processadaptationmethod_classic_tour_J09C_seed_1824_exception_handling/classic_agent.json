        "tool_calls": [
          {
            "name": "run_sqlite_query",
            "args": {
              "sqlite_command": "UPDATE J09C_temp SET ENTSCHEIDUNG = 'KSA' WHERE ENTSCHEIDUNG = 'EVU' AND HAUS IN (SELECT HAUS FROM J09C_temp GROUP BY HAUS HAVING COUNT(EQUNR) < 3)"
